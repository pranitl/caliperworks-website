---
import Layout from '../../layouts/Layout.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { createMailto } from '../../data/site';
import {
  customPricingItems,
  growthAssetDefinition,
  notFitReasons,
  pricingFaqs,
  pricingMeta,
  pricingOverview,
  pricingSeoStructuredOffers,
  pricingTerms,
  seoPricingPlans,
} from '../../data/pricing';
import { breadcrumbSchema, faqSchema, offerCatalogSchema } from '../../lib/seo';

const reviewHref = createMailto('Caliperworks Gap Review Request');
const structuredData = [
  breadcrumbSchema([{ name: 'Home', path: '/' }, { name: 'Pricing', path: '/pricing/' }]),
  offerCatalogSchema('Caliperworks SEO pricing', pricingSeoStructuredOffers),
  faqSchema(pricingFaqs),
];
---

<Layout title={pricingMeta.title} description={pricingMeta.description} canonicalPath="/pricing/" structuredData={structuredData}>
  <SiteHeader />
  <main class="bg-[#fbfaf7] text-slate-950">
    <section class="border-b border-slate-200 px-6 py-20 md:py-28">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
        <div>
          <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">{pricingOverview.eyebrow}</div>
          <h1 class="mt-6 max-w-5xl text-5xl font-semibold leading-[1.02] tracking-[-0.055em] md:text-7xl">{pricingOverview.headline}</h1>
        </div>
        <div>
          <p class="text-lg leading-8 text-slate-600">{pricingOverview.body}</p>
          <div class="mt-7 flex flex-wrap items-center gap-5">
            <a href={reviewHref} class="rounded-lg bg-blue-700 px-6 py-4 text-sm font-bold text-white hover:bg-slate-900">{pricingOverview.primaryCta}</a>
            <a href="#plans" class="text-sm font-bold text-blue-800">{pricingOverview.secondaryCta} →</a>
          </div>
        </div>
      </div>
    </section>

    <section id="plans" class="px-6 py-20 md:py-28">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-10 lg:grid-cols-[0.72fr_1.28fr]">
          <div>
            <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Packaged local visibility</div>
            <h2 class="mt-5 text-4xl font-semibold leading-tight tracking-[-0.045em] md:text-5xl">One standard of work. Three execution paces.</h2>
            <div class="mt-7 border-l border-slate-300 pl-5 text-base leading-7 text-slate-600">
              <div><strong class="text-slate-900">{pricingTerms.setupFee} setup</strong></div>
              <div><strong class="text-slate-900">{pricingTerms.minimumTerm} minimum</strong></div>
              <div class="mt-2">Monthly work begins after the setup foundation is complete.</div>
            </div>
          </div>

          <div class="overflow-x-auto">
            <div class="grid min-w-[760px] grid-cols-3 border-y border-slate-300">
              {seoPricingPlans.map((plan) => (
                <article id={plan.id} class:list={['border-r border-slate-300 px-7 py-8 last:border-r-0', plan.featured ? 'bg-[#f2f6fb]' : '']}>
                  <div class="flex items-center justify-between gap-3">
                    <div class="text-xs font-bold uppercase tracking-[0.2em] text-slate-500">{plan.name}</div>
                    {plan.featured && <div class="text-[10px] font-bold uppercase tracking-[0.16em] text-blue-700">Most common</div>}
                  </div>
                  <div class="mt-6 text-4xl font-semibold tracking-[-0.045em]">{plan.price}<span class="text-base font-medium text-slate-500">{plan.cadence}</span></div>
                  <div class="mt-5 min-h-14 font-semibold leading-6 text-slate-800">{plan.bestFor}</div>
                  <div class="mt-8 border-t border-slate-300 pt-6 text-sm font-semibold leading-6 text-blue-800">{plan.output}</div>
                  <ul class="mt-6 space-y-3 text-sm leading-6 text-slate-600">
                    {plan.fit.slice(0, 3).map((item) => <li>{item}</li>)}
                  </ul>
                  <a href={createMailto(plan.inquirySubject)} class="mt-8 inline-flex text-sm font-bold text-blue-800 hover:text-slate-950">{plan.ctaLabel} →</a>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-slate-200 bg-[#f2f6fb] px-6 py-20 md:py-24">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.72fr_1.28fr]">
        <div>
          <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">What the setup builds</div>
          <h2 class="mt-5 text-4xl font-semibold tracking-[-0.04em]">The execution foundation.</h2>
          <p class="mt-5 text-lg leading-8 text-slate-600">{pricingTerms.setupDescription}</p>
        </div>
        <div class="grid gap-px border-y border-slate-300 bg-slate-300 sm:grid-cols-2">
          {pricingTerms.setupItems.map((item, index) => (
            <div class="flex gap-4 bg-[#f2f6fb] p-5 text-sm font-semibold leading-6 text-slate-700"><span class="text-blue-700">0{index + 1}</span>{item}</div>
          ))}
        </div>
      </div>
    </section>

    <section class="px-6 py-20 md:py-28">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.72fr_1.28fr]">
        <div>
          <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Growth assets</div>
          <h2 class="mt-5 text-4xl font-semibold tracking-[-0.04em]">{growthAssetDefinition.headline}</h2>
          <p class="mt-5 text-lg leading-8 text-slate-600">{growthAssetDefinition.body}</p>
        </div>
        <div class="border-t border-slate-300">
          {growthAssetDefinition.examples.map((asset) => (
            <div class="grid gap-3 border-b border-slate-300 py-5 sm:grid-cols-[0.7fr_1.3fr]">
              <div class="font-semibold text-slate-900">{asset.type}</div>
              <div class="text-slate-600">{asset.example}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-y border-slate-200 bg-white px-6 py-20 md:py-28">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-12 lg:grid-cols-[0.72fr_1.28fr]">
          <div>
            <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Custom implementation</div>
            <h2 class="mt-5 text-4xl font-semibold leading-tight tracking-[-0.04em] md:text-5xl">Scoped to the workflow, not forced into a package.</h2>
            <p class="mt-5 text-lg leading-8 text-slate-600">These services depend on call flows, integrations, routing rules, existing accounts, handoffs, support, and implementation depth.</p>
          </div>
          <div class="border-t border-slate-300">
            {customPricingItems.map((service) => (
              <article id={service.id} class="grid gap-5 border-b border-slate-300 py-7 md:grid-cols-[0.7fr_1.3fr]">
                <div class="text-xl font-semibold tracking-[-0.02em]">{service.name}</div>
                <div>
                  <p class="leading-7 text-slate-600">{service.detail}</p>
                  <a href={createMailto(service.inquirySubject)} class="mt-4 inline-flex text-sm font-bold text-blue-800">Request custom scope →</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 py-20 md:py-28">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-2">
        <div>
          <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Fit</div>
          <h2 class="mt-5 text-4xl font-semibold tracking-[-0.04em]">A real offer, service area, and follow-up owner.</h2>
          <p class="mt-5 text-lg leading-8 text-slate-600">The strongest fit is a service business with active demand and a team ready to act on the work that gets shipped.</p>
        </div>
        <div>
          <div class="text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Probably not a fit</div>
          <div class="mt-5 border-t border-slate-300">
            {notFitReasons.map((reason) => <div class="border-b border-slate-300 py-4 text-slate-600">{reason}</div>)}
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-slate-200 bg-[#f2f6fb] px-6 py-20 md:py-24">
      <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
        <div>
          <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Choose the starting point</div>
          <h2 class="mt-5 max-w-3xl text-5xl font-semibold leading-tight tracking-[-0.05em]">Not sure whether the constraint is visibility, coverage, or follow-up?</h2>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">Request a gap review. We will recommend a packaged SEO pace, a custom implementation path, or a clear not-a-fit answer.</p>
        </div>
        <div class="lg:text-right"><a href={reviewHref} class="inline-flex rounded-lg bg-blue-700 px-7 py-4 text-sm font-bold text-white hover:bg-slate-900">Request a Gap Review</a></div>
      </div>
    </section>

    <section class="px-6 py-20 md:py-24">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.72fr_1.28fr]">
        <div><div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">FAQ</div><h2 class="mt-5 text-4xl font-semibold tracking-[-0.04em]">Questions about pricing.</h2></div>
        <div class="border-t border-slate-300">
          {pricingFaqs.map((faq) => (
            <details class="border-b border-slate-300 py-6"><summary class="cursor-pointer list-none text-xl font-semibold">{faq.question}</summary><p class="mt-4 text-lg leading-8 text-slate-600">{faq.answer}</p></details>
          ))}
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</Layout>
