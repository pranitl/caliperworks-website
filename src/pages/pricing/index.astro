---
import Layout from '../../layouts/Layout.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { createMailto } from '../../data/site';
import {
  customPricingItems,
  pricingMeta,
  pricingOverview,
  pricingSeoStructuredOffers,
  pricingTerms,
  seoPricingPlans,
} from '../../data/pricing';
import { breadcrumbSchema, offerCatalogSchema } from '../../lib/seo';

const structuredData = [
  breadcrumbSchema([{ name: 'Home', path: '/' }, { name: 'Pricing', path: '/pricing/' }]),
  offerCatalogSchema('Caliperworks pricing', pricingSeoStructuredOffers),
];
const generalInquiryHref = createMailto('Caliperworks Pricing Inquiry - Discovery Call');
const maxFeatureCount = Math.max(...seoPricingPlans.map((plan) => plan.features.length));
---

<Layout
  title={pricingMeta.title}
  description={pricingMeta.description}
  canonicalPath="/pricing/"
  structuredData={structuredData}
>
  <SiteHeader />
  <main class="bg-white text-slate-900">
    <section class="border-b-2 border-slate-100 px-6 py-20">
      <div class="mx-auto max-w-7xl">
        <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">{pricingOverview.eyebrow}</div>
        <h1 class="mt-6 max-w-5xl font-serif text-5xl font-black leading-tight italic md:text-7xl">
          {pricingOverview.headline}
        </h1>
        <p class="mt-8 max-w-3xl text-xl leading-relaxed text-slate-600">
          {pricingOverview.body}
        </p>
        <div class="mt-12 grid gap-4 md:grid-cols-3">
          <div class="rounded-[2rem] border-2 border-slate-900 bg-slate-50 p-6">
            <div class="text-xs font-black uppercase tracking-[0.3em] text-blue-700">Initial setup</div>
            <div class="mt-3 text-3xl font-black text-slate-900">{pricingTerms.setupFee}</div>
            <p class="mt-3 text-base leading-relaxed text-slate-600">
              {pricingTerms.setupDescription}
            </p>
          </div>
          <div class="rounded-[2rem] border-2 border-slate-900 bg-slate-50 p-6">
            <div class="text-xs font-black uppercase tracking-[0.3em] text-blue-700">Minimum term</div>
            <div class="mt-3 text-3xl font-black text-slate-900">{pricingTerms.minimumTerm}</div>
            <p class="mt-3 text-base leading-relaxed text-slate-600">
              {pricingTerms.termDescription}
            </p>
          </div>
          <div class="rounded-[2rem] border-2 border-slate-900 bg-slate-50 p-6">
            <div class="text-xs font-black uppercase tracking-[0.3em] text-blue-700">Included in every SEO plan</div>
            <div class="mt-3 text-3xl font-black text-slate-900">{pricingTerms.includedLabel}</div>
            <p class="mt-3 text-base leading-relaxed text-slate-600">
              {pricingTerms.includedDescription}
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
          <div>
            <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">SEO content creation & optimization</div>
            <h2 class="mt-6 max-w-4xl font-serif text-4xl font-black leading-tight md:text-5xl">
              Three plans, one setup, and enough runway for the work to matter.
            </h2>
          </div>
          <a
            href={generalInquiryHref}
            class="inline-flex items-center justify-center rounded-full border-2 border-slate-900 px-6 py-3 text-sm font-black text-slate-900 transition-colors hover:border-blue-800 hover:text-blue-800"
          >
            Email about pricing
          </a>
        </div>
        <div class="mt-10 grid gap-8 lg:grid-cols-3">
          {seoPricingPlans.map((plan) => (
            <article
              id={plan.id}
              class:list={[
                'flex h-full flex-col rounded-[2.5rem] border-4 p-10',
                plan.featured
                  ? 'border-blue-800 bg-blue-800 text-white shadow-[18px_18px_0_0_rgba(15,23,42,1)]'
                  : 'border-slate-900 bg-white text-slate-900 shadow-sm',
              ]}
            >
              <div class:list={['text-sm font-black uppercase tracking-[0.3em]', plan.featured ? 'text-blue-100' : 'text-blue-700']}>
                {plan.name}
              </div>
              <div class="mt-6 flex items-end gap-2">
                <div class="font-serif text-6xl font-black italic">{plan.price}</div>
                <div class:list={['pb-2 text-lg font-bold', plan.featured ? 'text-blue-100' : 'text-slate-500']}>{plan.cadence}</div>
              </div>
              <p class:list={['mt-6 text-lg leading-relaxed', plan.featured ? 'text-blue-50' : 'text-slate-600']}>
                {plan.summary}
              </p>
              <ul class="mt-8 grid gap-3 text-sm font-semibold">
                {Array.from({ length: maxFeatureCount }).map((_, index) => {
                  const feature = plan.features[index];

                  return (
                    <li
                      class:list={[
                        'min-h-[3.5rem] rounded-xl px-4 py-3',
                        plan.featured ? 'bg-white/10 text-white' : 'bg-slate-50 text-slate-700',
                        !feature && 'invisible',
                      ]}
                      aria-hidden={feature ? undefined : 'true'}
                    >
                      {feature ?? 'Placeholder feature'}
                    </li>
                  );
                })}
              </ul>
              <a
                href={createMailto(plan.inquirySubject)}
                class:list={[
                  'mt-auto pt-8 inline-flex items-center justify-center rounded-2xl px-6 py-4 text-base font-black transition-colors',
                  plan.featured
                    ? 'bg-white text-blue-900 hover:bg-slate-100'
                    : 'bg-slate-900 text-white hover:bg-blue-800',
                ]}
              >
                {`Email about ${plan.name}`}
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-y-2 border-slate-900 bg-slate-100 px-6 py-20">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.9fr_1.1fr]">
        <div>
          <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">What the setup covers</div>
          <h2 class="mt-6 font-serif text-4xl font-black leading-tight md:text-5xl">
            The first month is not generic onboarding.
          </h2>
        </div>
        <div class="space-y-5 text-lg leading-relaxed text-slate-700">
          <p>
            The setup is where we get clear on the business before content starts shipping. That includes the
            real value proposition, the way the business speaks, the local market, and what already sounds
            overused in the category.
          </p>
          <p>
            The point is simple: the output should fit the location, sound distinct, and match what makes the
            business worth choosing in the first place.
          </p>
        </div>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto max-w-7xl">
        <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">Custom pricing</div>
        <h2 class="mt-6 max-w-4xl font-serif text-4xl font-black leading-tight md:text-5xl">
          Voice agents and ads support are scoped after discovery.
        </h2>
        <p class="mt-6 max-w-3xl text-xl leading-relaxed text-slate-600">
          Those services depend too much on the workflow to pretend there is one public price that fits everyone.
        </p>
        <div class="mt-10 grid gap-8 md:grid-cols-2">
          {customPricingItems.map((service) => (
            <article id={service.id} class="rounded-[2rem] border-4 border-slate-900 bg-white p-8 shadow-sm">
              <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">{service.name}</div>
              <div class="mt-4 text-3xl font-black text-slate-900">Contact us to learn more</div>
              <p class="mt-5 text-lg leading-relaxed text-slate-600">{service.detail}</p>
              <a
                href={createMailto(service.inquirySubject)}
                class="mt-8 inline-flex items-center justify-center rounded-2xl bg-slate-900 px-6 py-4 text-base font-black text-white transition-colors hover:bg-blue-800"
              >
                {service.ctaLabel}
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t-2 border-slate-900 bg-blue-800 px-6 py-20 text-white">
      <div class="mx-auto max-w-5xl text-center">
        <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-100">Need help choosing?</div>
        <h2 class="mt-6 font-serif text-4xl font-black italic tracking-tight md:text-6xl">
          Reach out and we can sort out the right starting point.
        </h2>
        <p class="mx-auto mt-6 max-w-3xl text-xl leading-relaxed text-blue-100">
          If the bottleneck is unclear, start with the free audit. That is where we figure out whether SEO, voice, ads, or workflow cleanup should come first.
        </p>
        <a
          href={generalInquiryHref}
          class="mt-10 inline-flex items-center justify-center rounded-3xl bg-white px-10 py-5 text-xl font-black text-blue-900 transition-colors hover:bg-slate-100"
        >
          Start the free audit by email
        </a>
      </div>
    </section>
  </main>
  <SiteFooter />
</Layout>
