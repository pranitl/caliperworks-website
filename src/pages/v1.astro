---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Caliperworks - AI Integration for Small Business" description="Refined AI integration and process optimization for small businesses. We build AI that does the work.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,600&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

  <main class="bg-warm-white text-deep-charcoal min-h-screen">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-warm-white/90 backdrop-blur-md border-b border-neutral-100">
      <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <a href="/" class="text-2xl font-serif tracking-tighter">Caliperworks</a>
        <div class="hidden md:flex gap-10 text-sm tracking-widest uppercase font-medium">
          <a href="#problem" class="hover:text-brand-gold transition-colors duration-300">The Problem</a>
          <a href="#solutions" class="hover:text-brand-gold transition-colors duration-300">Solutions</a>
          <a href="#expertise" class="hover:text-brand-gold transition-colors duration-300">Expertise</a>
          <a href="#faq" class="hover:text-brand-gold transition-colors duration-300">FAQ</a>
        </div>
        <a href="#audit" class="px-6 py-2.5 bg-deep-charcoal text-warm-white text-sm font-medium hover:bg-neutral-800 transition-all duration-500 shadow-sm">
          Get an AI Audit
        </a>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative min-h-[90vh] flex items-center pt-20 overflow-hidden">
      <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">
        <div class="animate-fade-in-up">
          <div class="inline-flex items-center gap-3 mb-10 text-brand-gold text-xs font-semibold tracking-[0.3em] uppercase">
            <span class="w-12 h-px bg-brand-gold"></span>
            Precision Engineering
          </div>
          <h1 class="text-6xl md:text-8xl lg:text-[7rem] font-serif leading-[0.95] mb-10 tracking-tighter">
            AI that does <br/> <span class="italic text-brand-gold font-light">the work</span>, <br class="hidden md:block"/> so you don't have to.
          </h1>
          <p class="text-xl md:text-2xl text-neutral-500 mb-12 max-w-lg leading-relaxed font-light">
            We help small businesses integrate AI into their daily operations. Not just as a chatbot, but as a team member that books calls, qualifies leads, and optimizes your marketing.
          </p>
          <div class="flex flex-col sm:flex-row gap-6">
            <a href="#audit" class="px-10 py-5 bg-deep-charcoal text-warm-white text-lg font-medium hover:bg-neutral-800 transition-all duration-500 shadow-2xl shadow-neutral-300 group inline-flex items-center gap-4">
              Get an AI Audit
              <span class="w-8 h-px bg-brand-gold group-hover:w-12 transition-all duration-500"></span>
            </a>
          </div>
        </div>

        <div class="hidden lg:block relative animate-fade-in animation-delay-400 opacity-0 fill-mode-forwards">
          <!-- Conceptual visual: Minimalist architectural composition -->
          <div class="aspect-[4/5] bg-white border border-neutral-100 p-16 shadow-[0_40px_100px_-20px_rgba(0,0,0,0.1)] relative overflow-hidden group">
            <div class="absolute inset-0 bg-radial-gradient from-neutral-50 to-transparent opacity-50"></div>
            <div class="relative z-10 flex flex-col justify-between h-full border-l border-brand-gold/20 pl-12 py-4">
              <div class="space-y-2">
                <div class="text-brand-gold font-serif text-6xl italic opacity-20">01</div>
                <div class="text-neutral-300 uppercase tracking-[0.2em] text-xs font-bold">Process Audit</div>
              </div>
              
              <div class="w-full space-y-8">
                <div class="flex items-end gap-4">
                  <div class="w-1 h-32 bg-neutral-100"></div>
                  <div class="w-1 h-48 bg-brand-gold"></div>
                  <div class="w-1 h-24 bg-neutral-100"></div>
                  <div class="w-1 h-40 bg-neutral-100"></div>
                </div>
                <div class="text-brand-gold font-serif text-3xl italic tracking-tight">Caliperworks.</div>
              </div>

              <!-- Decorative element -->
              <div class="absolute top-0 right-0 p-8">
                <div class="w-16 h-16 border-t border-r border-brand-gold/30"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem Section -->
    <section id="problem" class="py-40 bg-white border-y border-neutral-50">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-xs font-bold tracking-[0.4em] uppercase text-brand-gold/60 mb-16">The Reality</h2>
        <p class="text-4xl md:text-6xl font-serif leading-[1.15] text-deep-charcoal mb-16 italic tracking-tight">
          "Most business owners know AI exists, but don't know how to use it beyond a basic chat interface."
        </p>
        <div class="w-24 h-px bg-brand-gold mx-auto mb-16"></div>
        <p class="text-xl md:text-2xl text-neutral-500 max-w-2xl mx-auto font-light leading-relaxed">
          You're busy running your business—HVAC, dental practice, or real estate agency. You don't have time to be an AI researcher. We bridge that gap by building tools that handle the repetitive work for you.
        </p>
      </div>
    </section>

    <!-- Solutions Section -->
    <section id="solutions" class="py-40 bg-warm-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col lg:flex-row lg:items-end justify-between mb-32 gap-12">
          <div class="max-w-3xl">
            <h2 class="text-xs font-bold tracking-[0.4em] uppercase text-brand-gold/60 mb-8">Our Solutions</h2>
            <p class="text-6xl md:text-7xl font-serif tracking-tighter leading-[0.95]">Refined tools for <br/> <span class="text-brand-gold italic">uninterrupted</span> growth.</p>
          </div>
          <p class="text-neutral-500 max-w-xs font-light text-lg leading-relaxed border-l border-brand-gold/20 pl-8">
            We move beyond prompts and focus on outcomes. Real growth, measurable time saved.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-1px bg-neutral-200 border border-neutral-200">
          <!-- Audit Card -->
          <div class="group p-12 lg:p-16 bg-warm-white hover:bg-white transition-all duration-700">
            <div class="text-brand-gold mb-12 text-3xl font-serif italic">01.</div>
            <h3 class="text-3xl font-serif mb-6 leading-tight">AI Audits: <br/> Find the Wins</h3>
            <p class="text-neutral-500 mb-12 font-light leading-relaxed text-lg">
              We look at your current processes—how you handle leads, how you schedule, and how you market. Then, we identify exactly where AI can save you time and increase your revenue.
            </p>
            <div class="inline-flex items-center gap-4 text-xs font-bold tracking-widest uppercase text-brand-gold group-hover:translate-x-2 transition-transform duration-500">
              Explore Audit
              <span class="w-8 h-px bg-brand-gold"></span>
            </div>
          </div>

          <!-- Voice Card -->
          <div class="group p-12 lg:p-16 bg-warm-white hover:bg-white transition-all duration-700">
            <div class="text-brand-gold mb-12 text-3xl font-serif italic">02.</div>
            <h3 class="text-3xl font-serif mb-6 leading-tight">Voice Agents: <br/> 24/7 Front Desk</h3>
            <p class="text-neutral-500 mb-12 font-light leading-relaxed text-lg">
              Stop missing calls. Our voice agents answer the phone at any time, qualify prospects, and book appointments directly into your calendar. A receptionist who never sleeps.
            </p>
            <div class="inline-flex items-center gap-4 text-xs font-bold tracking-widest uppercase text-brand-gold group-hover:translate-x-2 transition-transform duration-500">
              Explore Voice
              <span class="w-8 h-px bg-brand-gold"></span>
            </div>
          </div>

          <!-- Marketing Card -->
          <div class="group p-12 lg:p-16 bg-warm-white hover:bg-white transition-all duration-700">
            <div class="text-brand-gold mb-12 text-3xl font-serif italic">03.</div>
            <h3 class="text-3xl font-serif mb-6 leading-tight">Marketing Engine: <br/> Real Growth</h3>
            <p class="text-neutral-500 mb-12 font-light leading-relaxed text-lg">
              Our SEO and SEM automation tools don't just "increase visibility." We help clients rank in ChatGPT and Google AI Overviews while generating 20% more leads.
            </p>
            <div class="inline-flex items-center gap-4 text-xs font-bold tracking-widest uppercase text-brand-gold group-hover:translate-x-2 transition-transform duration-500">
              Explore Marketing
              <span class="w-8 h-px bg-brand-gold"></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Metrics Section -->
    <section class="py-32 bg-deep-charcoal text-warm-white overflow-hidden relative">
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <div class="h-full w-full bg-[radial-gradient(#B89B72_1px,transparent_1px)] [background-size:40px_40px]"></div>
      </div>
      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-16 lg:gap-8">
          <div class="text-center lg:text-left">
            <div class="text-5xl md:text-7xl font-serif text-brand-gold mb-4 leading-none">+200%</div>
            <div class="text-xs uppercase tracking-[0.3em] text-neutral-400 font-medium">Monthly engaged visitors</div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-5xl md:text-7xl font-serif text-brand-gold mb-4 leading-none">P1</div>
            <div class="text-xs uppercase tracking-[0.3em] text-neutral-400 font-medium">Google Ranking Secured</div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-5xl md:text-7xl font-serif text-brand-gold mb-4 leading-none">24/7</div>
            <div class="text-xs uppercase tracking-[0.3em] text-neutral-400 font-medium">Reception Coverage</div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-5xl md:text-7xl font-serif text-brand-gold mb-4 leading-none">+20%</div>
            <div class="text-xs uppercase tracking-[0.3em] text-neutral-400 font-medium">Lead conversion growth</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Industry Expertise Section -->
    <section id="expertise" class="py-40 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-32">
          <h2 class="text-xs font-bold tracking-[0.4em] uppercase text-brand-gold/60 mb-8">Industry Expertise</h2>
          <p class="text-5xl font-serif tracking-tight">Customized for your craft.</p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-px bg-neutral-100 border border-neutral-100">
          {[
            { name: "Home Care Agencies", desc: "Managing caregiver schedules and client inquiries." },
            { name: "HVAC & Plumbing", desc: "Handling emergency calls and booking service windows." },
            { name: "Laundromats", desc: "Optimizing pick-up and delivery logistics." },
            { name: "Dentists", desc: "Reducing no-shows and automating reminders." },
            { name: "Real Estate", desc: "Qualifying buyer and seller leads instantly." }
          ].map((industry) => (
            <div class="bg-white p-10 group hover:bg-neutral-50 transition-colors duration-500">
              <h3 class="text-2xl font-serif mb-4 leading-tight group-hover:text-brand-gold transition-colors duration-500">{industry.name}</h3>
              <p class="text-sm text-neutral-400 font-light leading-relaxed">{industry.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section id="faq" class="py-40 bg-warm-white border-t border-neutral-100">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid lg:grid-cols-3 gap-20">
          <div>
            <h2 class="text-xs font-bold tracking-[0.4em] uppercase text-brand-gold/60 mb-8">FAQ</h2>
            <p class="text-4xl font-serif leading-tight">Common inquiries <br/> <span class="italic text-brand-gold">& answers.</span></p>
          </div>
          
          <div class="lg:col-span-2 space-y-16">
            {[
              { 
                q: "How is this different from ChatGPT?", 
                a: "ChatGPT is a tool you talk to. We build systems that do work. Whether it's answering your phones or managing your SEO, our tools are integrated into your existing business flow." 
              },
              { 
                q: "Is it hard to set up?", 
                a: "No. We handle the technical integration. You just tell us how your business works, and we build the AI to match it." 
              },
              { 
                q: "Is AI expensive?", 
                a: "We focus on ROI. Most of our tools pay for themselves by saving hours of manual work or capturing leads that would otherwise be lost." 
              },
              { 
                q: "Will my customers know they're talking to an AI?", 
                a: "Our voice and text agents are designed to be helpful and professional. We prioritize accuracy and a smooth experience over 'trying to trick' the customer." 
              }
            ].map((item) => (
              <div class="group border-l-2 border-neutral-100 pl-8 hover:border-brand-gold transition-colors duration-500">
                <h3 class="text-2xl font-serif mb-6">{item.q}</h3>
                <p class="text-neutral-500 font-light leading-relaxed text-lg">
                  {item.a}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- CTA / Audit Section -->
    <section id="audit" class="py-40 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="bg-deep-charcoal p-12 md:p-24 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-64 h-64 border-t border-r border-brand-gold/10 m-12"></div>
          <div class="relative z-10 max-w-2xl">
            <h2 class="text-4xl md:text-6xl font-serif text-warm-white mb-10 leading-tight">
              Ready to <span class="italic text-brand-gold">calibrate</span> your operations?
            </h2>
            <p class="text-xl text-neutral-400 mb-12 font-light leading-relaxed">
              Book a session to identify high-impact AI opportunities in your business. No fluff, just a clear roadmap for automation and growth.
            </p>
            <a href="#" class="inline-flex items-center gap-6 px-10 py-5 bg-brand-gold text-deep-charcoal text-lg font-bold hover:bg-white transition-all duration-500 group">
              Schedule Your AI Audit
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-2 transition-transform duration-500"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-24 bg-deep-charcoal text-neutral-400 border-t border-white/5">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-16 mb-24">
          <div>
            <div class="text-4xl font-serif text-warm-white mb-8 tracking-tighter">Caliperworks</div>
            <p class="max-w-xs font-light leading-relaxed text-lg">
              AI for the real world. Elevating small businesses through refined integration and surgical precision.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row gap-12 text-xs font-bold tracking-[0.3em] uppercase">
            <a href="#" class="hover:text-brand-gold transition-colors duration-300">Get Started</a>
            <a href="#" class="hover:text-brand-gold transition-colors duration-300">Contact</a>
            <a href="#" class="hover:text-brand-gold transition-colors duration-300">Privacy</a>
          </div>
        </div>
        <div class="pt-12 border-t border-white/5 text-[10px] font-medium tracking-[0.2em] uppercase flex flex-col sm:flex-row justify-between gap-6 opacity-40">
          <span>&copy; 2025 Caliperworks. All rights reserved.</span>
          <span>Stable. Professional. Proven.</span>
        </div>
      </div>
    </footer>
  </main>
</Layout>

<style is:global>
  :root {
    scroll-behavior: smooth;
  }
  
  .fill-mode-forwards {
    animation-fill-mode: forwards;
  }

  /* Custom radial gradient for backgrounds */
  .bg-radial-gradient {
    background: radial-gradient(circle at center, var(--tw-gradient-from), var(--tw-gradient-to));
  }
</style>
