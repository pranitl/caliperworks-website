---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Caliperworks | Your Modern AI Partner">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style is:global>
    :root {
      --color-teal-light: #E0F2F1;
      --color-sage: #81C784;
      --color-sage-dark: #66BB6A;
      --color-off-white: #F5F5F5;
      --color-dark-teal: #004D40;
    }

    body {
      font-family: 'Lexend', sans-serif;
      background-color: var(--color-off-white);
      color: var(--color-dark-teal);
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: 'Outfit', sans-serif;
    }

    .glass-card {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.3);
      border-radius: 1.5rem;
      box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);
    }

    .gradient-bg {
      background: radial-gradient(circle at 10% 20%, rgba(224, 242, 241, 1) 0%, rgba(129, 199, 132, 0.2) 90%);
    }

    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .stagger-1 { transition-delay: 0.1s; }
    .stagger-2 { transition-delay: 0.2s; }
    .stagger-3 { transition-delay: 0.3s; }
    .stagger-4 { transition-delay: 0.4s; }
    .stagger-5 { transition-delay: 0.5s; }
    .stagger-6 { transition-delay: 0.6s; }

    @keyframes blob {
      0% { transform: translate(0px, 0px) scale(1); }
      33% { transform: translate(30px, -50px) scale(1.1); }
      66% { transform: translate(-20px, 20px) scale(0.9); }
      100% { transform: translate(0px, 0px) scale(1); }
    }
    .animate-blob {
      animation: blob 7s infinite;
    }
    .animation-delay-2000 { animation-delay: 2s; }
    .animation-delay-4000 { animation-delay: 4s; }
  </style>

  <main class="min-h-screen selection:bg-teal-200 selection:text-teal-900">
    
    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-4">
      <div class="max-w-7xl mx-auto flex items-center justify-between glass-card px-6 py-3">
        <div class="flex items-center space-x-2">
          <div class="w-8 h-8 bg-teal-600 rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-lg">C</span>
          </div>
          <span class="text-xl font-bold tracking-tight text-teal-900">Caliperworks</span>
        </div>
        <div class="hidden md:flex items-center space-x-8 text-sm font-medium">
          <a href="#problem" class="hover:text-teal-600 transition-colors">The Problem</a>
          <a href="#solutions" class="hover:text-teal-600 transition-colors">Solutions</a>
          <a href="#expertise" class="hover:text-teal-600 transition-colors">Expertise</a>
          <a href="#faq" class="hover:text-teal-600 transition-colors">FAQ</a>
        </div>
        <a href="#audit" class="bg-teal-600 hover:bg-teal-700 text-white px-5 py-2 rounded-full text-sm font-semibold transition-all hover:shadow-lg active:scale-95">
          Get an AI Audit
        </a>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 md:pt-48 md:pb-32 px-6 overflow-hidden gradient-bg">
      <div class="max-w-7xl mx-auto relative z-10">
        <div class="max-w-3xl">
          <div class="inline-flex items-center px-3 py-1 rounded-full bg-teal-100 text-teal-700 text-xs font-bold uppercase tracking-wider mb-6 animate-fade-in">
            <span class="relative flex h-2 w-2 mr-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-teal-500"></span>
            </span>
            Modern AI for Small Business
          </div>
          <h1 class="text-5xl md:text-7xl font-bold text-teal-900 leading-tight mb-6 animate-fade-in">
            AI that does the work, <br/><span class="text-teal-600">so you don't have to.</span>
          </h1>
          <p class="text-xl md:text-2xl text-teal-800/80 mb-10 leading-relaxed animate-fade-in animation-delay-200">
            We help small businesses integrate AI into their daily operations. Not just as a chatbot, but as a team member that books calls, qualifies leads, and optimizes your marketing.
          </p>
          <div class="flex flex-col sm:flex-row space-y-4 sm:space-y-0 sm:space-x-4 animate-fade-in animation-delay-400">
            <a href="#audit" class="bg-teal-600 hover:bg-teal-700 text-white px-8 py-4 rounded-2xl text-lg font-bold transition-all hover:shadow-xl hover:-translate-y-1 text-center">
              Get an AI Audit
            </a>
            <a href="#solutions" class="bg-white/50 hover:bg-white text-teal-900 px-8 py-4 rounded-2xl text-lg font-bold transition-all hover:shadow-md border border-teal-100 text-center">
              Explore Solutions
            </a>
          </div>
        </div>
      </div>
      
      <!-- Abstract Background Elements -->
      <div class="absolute top-1/2 right-0 -translate-y-1/2 w-1/2 h-full hidden lg:block">
        <div class="relative w-full h-full">
          <div class="absolute top-10 right-10 w-64 h-64 bg-teal-200 rounded-full mix-blend-multiply filter blur-3xl opacity-70 animate-blob"></div>
          <div class="absolute bottom-10 right-40 w-72 h-72 bg-sage rounded-full mix-blend-multiply filter blur-3xl opacity-60 animate-blob animation-delay-2000"></div>
          <div class="absolute top-40 right-60 w-56 h-56 bg-white rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob animation-delay-4000"></div>
          
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 glass-card p-8 rotate-3 hover:rotate-0 transition-transform duration-500 w-[400px]">
            <div class="space-y-4">
              <div class="flex items-center space-x-3">
                <div class="w-10 h-10 rounded-full bg-teal-100 flex items-center justify-center text-teal-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
                </div>
                <div class="h-4 bg-teal-100 rounded w-3/4"></div>
              </div>
              <div class="space-y-2">
                <div class="h-3 bg-teal-50 rounded w-full"></div>
                <div class="h-3 bg-teal-50 rounded w-5/6"></div>
              </div>
              <div class="pt-4 border-t border-teal-50 flex justify-end">
                <div class="h-8 bg-teal-600 rounded-lg w-24"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem Section -->
    <section id="problem" class="py-24 px-6 bg-white">
      <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <div class="reveal">
            <h2 class="text-3xl md:text-5xl font-bold text-teal-900 mb-8 leading-tight">
              You're busy running your business. <br/><span class="text-sage-dark">Not being an AI researcher.</span>
            </h2>
            <div class="space-y-6 text-lg text-teal-800/80 leading-relaxed">
              <p>
                Most business owners know AI exists, but don't know how to use it beyond a basic chat interface. You're busy running your business—HVAC, dental practice, or real estate agency.
              </p>
              <p>
                You don't have time to keep up with every new tool. We bridge that gap by building systems that handle the repetitive work for you, so you can focus on what you do best.
              </p>
            </div>
          </div>
          <div class="relative reveal stagger-2">
            <div class="glass-card p-8 bg-teal-50/50 border-teal-100">
              <div class="space-y-4">
                <div class="flex items-start space-x-4">
                  <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center text-red-500 shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  </div>
                  <div>
                    <p class="font-bold text-teal-900">Information Overload</p>
                    <p class="text-sm text-teal-800/70">Too many tools, not enough clear answers on what actually works for your industry.</p>
                  </div>
                </div>
                <div class="flex items-start space-x-4">
                  <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center text-red-500 shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  </div>
                  <div>
                    <p class="font-bold text-teal-900">Time Poverty</p>
                    <p class="text-sm text-teal-800/70">Manually following up on leads and scheduling takes hours away from real growth.</p>
                  </div>
                </div>
                <div class="flex items-start space-x-4">
                  <div class="w-10 h-10 rounded-full bg-teal-100 flex items-center justify-center text-teal-600 shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  </div>
                  <div>
                    <p class="font-bold text-teal-600">Caliperworks Solution</p>
                    <p class="text-sm text-teal-800/70">We build the bridges. You reap the rewards of automation without the headache.</p>
                  </div>
                </div>
              </div>
            </div>
            <!-- Decorative circle -->
            <div class="absolute -bottom-6 -right-6 w-24 h-24 bg-sage rounded-full opacity-20 -z-10"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Solutions Section -->
    <section id="solutions" class="py-24 px-6 gradient-bg">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-20 reveal">
          <h2 class="text-4xl md:text-5xl font-bold text-teal-900 mb-6">Our Solutions</h2>
          <p class="text-xl text-teal-800/70 max-w-2xl mx-auto">We don't just sell software. We integrate intelligence into your business.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <!-- AI Audits -->
          <div class="glass-card p-10 hover:shadow-2xl transition-all duration-500 group reveal">
            <div class="w-16 h-16 bg-teal-100 rounded-2xl flex items-center justify-center text-teal-600 mb-8 group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            </div>
            <h3 class="text-2xl font-bold text-teal-900 mb-4">AI Audits: Find the Wins</h3>
            <p class="text-teal-800/70 mb-8 leading-relaxed">
              We look at your current processes—how you handle leads, how you schedule, and how you market. Then, we identify exactly where AI can save you time and increase your revenue.
            </p>
            <ul class="space-y-3 text-sm font-medium text-teal-900 mb-8">
              <li class="flex items-center space-x-2">
                <svg class="h-5 w-5 text-sage" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span>Process mapping</span>
              </li>
              <li class="flex items-center space-x-2">
                <svg class="h-5 w-5 text-sage" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span>ROI identification</span>
              </li>
            </ul>
          </div>

          <!-- Voice Agents -->
          <div class="glass-card p-10 hover:shadow-2xl transition-all duration-500 group border-teal-200 bg-white/80 reveal stagger-2">
            <div class="w-16 h-16 bg-sage/20 rounded-2xl flex items-center justify-center text-sage-dark mb-8 group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>
            </div>
            <h3 class="text-2xl font-bold text-teal-900 mb-4">Voice Agents: Your 24/7 Front Desk</h3>
            <p class="text-teal-800/70 mb-8 leading-relaxed">
              Stop missing calls. Our voice agents answer the phone at any time, qualify prospects, and book appointments directly into your calendar.
            </p>
            <ul class="space-y-3 text-sm font-medium text-teal-900 mb-8">
              <li class="flex items-center space-x-2">
                <svg class="h-5 w-5 text-sage" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span>Automated booking</span>
              </li>
              <li class="flex items-center space-x-2">
                <svg class="h-5 w-5 text-sage" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span>Lead qualification</span>
              </li>
            </ul>
          </div>

          <!-- Marketing Engine -->
          <div class="glass-card p-10 hover:shadow-2xl transition-all duration-500 group reveal stagger-3">
            <div class="w-16 h-16 bg-teal-100 rounded-2xl flex items-center justify-center text-teal-600 mb-8 group-hover:scale-110 transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
            </div>
            <h3 class="text-2xl font-bold text-teal-900 mb-4">Marketing Engine: Real Growth</h3>
            <p class="text-teal-800/70 mb-8 leading-relaxed">
              Our SEO and SEM automation tools don't just "increase visibility." We rank you in ChatGPT and Google AI Overviews while driving qualified leads.
            </p>
            <div class="bg-teal-50 rounded-xl p-4 border border-teal-100">
              <p class="text-xs font-bold text-teal-600 uppercase tracking-widest mb-2">Success metrics</p>
              <p class="text-sm font-semibold text-teal-900">+200% Engaged Visitors</p>
              <div class="w-full bg-teal-200 h-1.5 rounded-full mt-1 overflow-hidden">
                <div class="bg-teal-600 h-full w-[80%] rounded-full"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Industry Expertise -->
    <section id="expertise" class="py-24 px-6 bg-white overflow-hidden">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row items-end justify-between mb-16 space-y-4 md:space-y-0 reveal">
          <div class="max-w-xl">
            <h2 class="text-4xl md:text-5xl font-bold text-teal-900 mb-4">Built for the Real World</h2>
            <p class="text-lg text-teal-800/70">We've implemented custom AI solutions across a diverse range of service-based industries.</p>
          </div>
          <div class="flex space-x-2">
            <button class="w-12 h-12 rounded-full border border-teal-100 flex items-center justify-center hover:bg-teal-50 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
            </button>
            <button class="w-12 h-12 rounded-full border border-teal-100 flex items-center justify-center hover:bg-teal-50 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </button>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {[
            { title: "Home Care Agencies", desc: "Managing caregiver schedules and client inquiries.", icon: "🏠" },
            { title: "HVAC & Plumbing", desc: "Handling emergency calls and booking service windows.", icon: "🔧" },
            { title: "Laundromats", desc: "Optimizing pick-up and delivery logistics.", icon: "🧺" },
            { title: "Dentists", desc: "Reducing no-shows and automating appointment reminders.", icon: "🦷" },
            { title: "Real Estate", desc: "Qualifying buyer and seller leads instantly.", icon: "🏢" }
          ].map((item, i) => (
            <div class={`glass-card p-8 border-teal-50 hover:-translate-y-2 transition-transform reveal stagger-${i+1}`}>
              <div class="text-4xl mb-6">{item.icon}</div>
              <h4 class="text-xl font-bold text-teal-900 mb-3">{item.title}</h4>
              <p class="text-teal-800/70 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
          <div class="glass-card p-8 bg-teal-600 text-white flex flex-col justify-center items-center text-center reveal stagger-6">
            <h4 class="text-xl font-bold mb-4">Your Industry?</h4>
            <p class="text-teal-50/80 text-sm mb-6">We adapt our core technology to fit your unique business flow.</p>
            <a href="#contact" class="text-sm font-bold underline decoration-2 underline-offset-4">Let's talk</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section id="faq" class="py-24 px-6 gradient-bg">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-teal-900 mb-16 text-center reveal">Common Questions</h2>
        <div class="space-y-4">
          {[
            { q: "How is this different from ChatGPT?", a: "ChatGPT is a tool you talk to. We build systems that *do work*. Whether it's answering your phones or managing your SEO, our tools are integrated into your existing business flow." },
            { q: "Is it hard to set up?", a: "No. We handle the technical integration. You just tell us how your business works, and we build the AI to match it." },
            { q: "Is AI expensive?", a: "We focus on ROI. Most of our tools pay for themselves by saving hours of manual work or capturing leads that would otherwise be lost." },
            { q: "Will my customers know they're talking to an AI?", a: "Our voice and text agents are designed to be helpful and professional. We prioritize accuracy and a smooth experience over \"trying to trick\" the customer." }
          ].map((item, i) => (
            <details class={`glass-card group open:bg-white transition-all duration-300 reveal stagger-${i+1}`}>
              <summary class="list-none px-8 py-6 flex items-center justify-between cursor-pointer font-bold text-teal-900">
                {item.q}
                <span class="w-8 h-8 rounded-full bg-teal-50 flex items-center justify-center group-open:rotate-180 transition-transform">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </span>
              </summary>
              <div class="px-8 pb-6 text-teal-800/70 leading-relaxed">
                {item.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-teal-950 text-white py-20 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-4 gap-12 mb-16">
          <div class="col-span-2">
            <div class="flex items-center space-x-2 mb-6">
              <div class="w-8 h-8 bg-teal-500 rounded-lg flex items-center justify-center">
                <span class="text-white font-bold text-lg">C</span>
              </div>
              <span class="text-2xl font-bold tracking-tight">Caliperworks</span>
            </div>
            <p class="text-teal-200/60 max-w-sm text-lg">
              AI for the real world. Integrating intelligence into your daily operations.
            </p>
          </div>
          <div>
            <h5 class="font-bold mb-6 text-teal-400">Quick Links</h5>
            <ul class="space-y-4 text-teal-200/80">
              <li><a href="#" class="hover:text-white transition-colors">Get Started</a></li>
              <li><a href="#" class="hover:text-white transition-colors">Solutions</a></li>
              <li><a href="#" class="hover:text-white transition-colors">Case Studies</a></li>
            </ul>
          </div>
          <div>
            <h5 class="font-bold mb-6 text-teal-400">Contact</h5>
            <ul class="space-y-4 text-teal-200/80">
              <li><a href="mailto:hello@caliperworks.com" class="hover:text-white transition-colors">hello@caliperworks.com</a></li>
              <li><a href="#" class="hover:text-white transition-colors">Privacy Policy</a></li>
            </ul>
          </div>
        </div>
        <div class="pt-8 border-t border-teal-900 flex flex-col md:flex-row items-center justify-between text-sm text-teal-200/40">
          <p>© 2024 Caliperworks. All rights reserved.</p>
          <div class="flex space-x-6 mt-4 md:mt-0">
            <a href="#" class="hover:text-white transition-colors">Twitter</a>
            <a href="#" class="hover:text-white transition-colors">LinkedIn</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Interactive Reveal Script -->
    <script>
      const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, observerOptions);

      document.querySelectorAll('.reveal').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </main>
</Layout>
