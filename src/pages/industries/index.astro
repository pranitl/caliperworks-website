---
import Layout from '../../layouts/Layout.astro';
import SectionCta from '../../components/SectionCta.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import {
  industries,
  industryHref,
  serviceMap,
} from '../../data/site';
import { breadcrumbSchema, itemListSchema } from '../../lib/seo';

const structuredData = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Industries', path: '/industries/' },
  ]),
  itemListSchema(
    'Caliperworks industry pages',
    industries.map((industry) => ({
      name: industry.name,
      path: industryHref(industry.slug),
    }))
  ),
];
---

<Layout
  title="Industries Caliperworks Supports | Caliperworks"
  description="See how Caliperworks adapts AI process audits, voice agents, and SEO systems for specific small-business industries."
  canonicalPath="/industries/"
  structuredData={structuredData}
>
  <SiteHeader />
  <main class="bg-white text-slate-900">
    <section class="border-b-2 border-slate-100 px-6 py-20">
      <div class="mx-auto max-w-7xl">
        <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">Industries</div>
        <h1 class="mt-6 max-w-4xl font-serif text-5xl font-black leading-tight italic md:text-7xl">
          AI systems tailored to the way each industry actually sells
        </h1>
        <p class="mt-8 max-w-3xl text-xl leading-relaxed text-slate-600">
          Caliperworks works best in businesses where marketing, intake, qualification, and
          follow-up all have to work together. The point is not one fixed AI product. It is
          finding the mix of audit, voice, search, ads, and workflow improvements that fits how the
          business actually operates.
        </p>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto grid max-w-7xl gap-8 md:grid-cols-2 xl:grid-cols-3">
        {industries.map((industry) => (
          <article class="flex h-full flex-col rounded-[2.25rem] border-4 border-slate-200 bg-white p-8">
            <h2 class="text-3xl font-black text-slate-900">{industry.name}</h2>
            <p class="mt-5 flex-grow text-lg leading-relaxed text-slate-600">{industry.summary}</p>
            <div class="mt-8 flex flex-wrap gap-2">
              {industry.relatedServices.map((slug) => (
                <span class="rounded-full border border-blue-100 bg-blue-50 px-3 py-1 text-xs font-black uppercase tracking-[0.2em] text-blue-800">
                  {serviceMap[slug].shortLabel}
                </span>
              ))}
            </div>
            <a
              href={industryHref(industry.slug)}
              class="mt-8 inline-flex items-center gap-3 text-base font-black text-slate-900 transition-colors hover:text-blue-800"
            >
              See {industry.name} solutions
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>
    </section>

    <SectionCta
      headline="Need an industry-specific starting point?"
      body="We can map where audit work, voice handling, search growth, or workflow automation will make the biggest difference in your specific industry."
      buttonText="Request an Industry Audit"
      subject="Caliperworks Industry Inquiry"
    />
  </main>
  <SiteFooter />
</Layout>
