---
import type { Industry } from '../../data/site';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionCta from '../../components/SectionCta.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import Layout from '../../layouts/Layout.astro';
import {
  caseStudyHref,
  caseStudyMap,
  industries,
  industryHref,
  serviceHref,
  serviceMap,
} from '../../data/site';
import { breadcrumbSchema, faqSchema } from '../../lib/seo';

export function getStaticPaths() {
  return industries.map((industry) => ({ params: { slug: industry.slug }, props: { industry } }));
}

const { industry }: { industry: Industry } = Astro.props;
const relatedServices = industry.relatedServices.map((slug) => serviceMap[slug]);
const relatedCaseStudies = industry.relatedCaseStudies.map((slug) => caseStudyMap[slug]);
const structuredData = [
  breadcrumbSchema([{ name: 'Home', path: '/' }, { name: 'Industries', path: '/industries/' }, { name: industry.name, path: industryHref(industry.slug) }]),
  faqSchema(industry.faq),
];
---

<Layout title={industry.metaTitle} description={industry.metaDescription} canonicalPath={industryHref(industry.slug)} structuredData={structuredData}>
  <SiteHeader />
  <main class="bg-[#fbfaf7] text-slate-950">
    <section class="border-b border-slate-200 px-6 py-16 md:py-24">
      <div class="mx-auto max-w-7xl">
        <Breadcrumbs items={[{ href: '/', label: 'Home' }, { href: '/industries/', label: 'Industries' }, { href: industryHref(industry.slug), label: industry.name }]} />
        <div class="mt-10 grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
          <div>
            <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Industry context · {industry.name}</div>
            <h1 class="mt-6 max-w-4xl text-5xl font-semibold leading-[1.02] tracking-[-0.055em] md:text-7xl">{industry.heroTitle}</h1>
            <p class="mt-7 max-w-2xl text-xl leading-8 text-slate-600">{industry.heroDescription}</p>
          </div>
          <div class="border-l border-slate-300 pl-7">
            <div class="text-xs font-bold uppercase tracking-[0.18em] text-slate-400">The operating context</div>
            <p class="mt-4 text-xl leading-8 text-slate-700">{industry.summary}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 py-20 md:py-28">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.72fr_1.28fr]">
        <div>
          <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Where the path breaks</div>
          <h2 class="mt-5 text-4xl font-semibold leading-tight tracking-[-0.04em] md:text-5xl">Start with a recognizable condition.</h2>
        </div>
        <div class="border-t border-slate-300">
          {industry.painPoints.map((painPoint, index) => (
            <div class="grid gap-4 border-b border-slate-300 py-6 sm:grid-cols-[4rem_1fr]"><div class="text-sm font-semibold text-blue-700">0{index + 1}</div><p class="text-lg leading-8 text-slate-700">{painPoint}</p></div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-y border-slate-200 bg-[#f2f6fb] px-6 py-20 md:py-24">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-12 lg:grid-cols-[0.72fr_1.28fr]">
          <div>
            <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">What changes</div>
            <h2 class="mt-5 text-4xl font-semibold tracking-[-0.04em]">A practical improvement path.</h2>
          </div>
          <div class="grid gap-px border-y border-slate-300 bg-slate-300 md:grid-cols-3">
            {industry.automations.map((automation, index) => (
              <div class="bg-[#f2f6fb] p-7"><div class="text-sm font-semibold text-blue-700">0{index + 1}</div><p class="mt-6 text-lg leading-8 text-slate-700">{automation}</p></div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 py-20 md:py-28">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.72fr_1.28fr]">
        <div>
          <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Relevant capabilities</div>
          <h2 class="mt-5 text-4xl font-semibold tracking-[-0.04em]">Use only the parts the constraint requires.</h2>
        </div>
        <div class="border-t border-slate-300">
          {relatedServices.map((service) => (
            <article class="grid gap-5 border-b border-slate-300 py-7 md:grid-cols-[0.7fr_1.3fr]">
              <h3 class="text-xl font-semibold">{service.name}</h3>
              <div><p class="leading-7 text-slate-600">{service.teaser}</p><a href={serviceHref(service.slug)} class="mt-4 inline-flex text-sm font-bold text-blue-800">Explore the service →</a></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    {relatedCaseStudies.length > 0 && (
      <section class="border-y border-slate-200 bg-white px-6 py-20 md:py-24">
        <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.72fr_1.28fr]">
          <div><div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Relevant proof</div><h2 class="mt-5 text-4xl font-semibold tracking-[-0.04em]">Same-industry context.</h2></div>
          <div class="border-t border-slate-300">
            {relatedCaseStudies.map((caseStudy) => (
              <article class="border-b border-slate-300 py-7"><div class="text-xs font-bold uppercase tracking-[0.18em] text-slate-400">{caseStudy.clientLabel} · {caseStudy.location}</div><h3 class="mt-3 text-2xl font-semibold">{caseStudy.title}</h3><p class="mt-3 leading-7 text-slate-600">{caseStudy.teaser}</p><a href={caseStudyHref(caseStudy.slug)} class="mt-4 inline-flex text-sm font-bold text-blue-800">Read the case study →</a></article>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="px-6 py-20 md:py-24">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.72fr_1.28fr]">
        <div><div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">FAQ</div><h2 class="mt-5 text-4xl font-semibold tracking-[-0.04em]">Questions from {industry.name.toLowerCase()}.</h2></div>
        <div class="border-t border-slate-300">
          {industry.faq.map((faq) => <details class="border-b border-slate-300 py-6"><summary class="cursor-pointer list-none text-xl font-semibold">{faq.question}</summary><p class="mt-4 text-lg leading-8 text-slate-600">{faq.answer}</p></details>)}
        </div>
      </div>
    </section>

    <SectionCta headline={`Find the first constraint worth fixing for ${industry.name.toLowerCase()}.`} body="Start with the gap review and we will map the relevant visibility, coverage, and follow-up conditions before recommending a packaged or custom implementation path." />
  </main>
  <SiteFooter />
</Layout>
