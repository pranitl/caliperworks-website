---
import type { Industry } from '../../data/site';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionCta from '../../components/SectionCta.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import Layout from '../../layouts/Layout.astro';
import {
  caseStudyHref,
  caseStudyMap,
  industries,
  industryHref,
  serviceHref,
  serviceMap,
} from '../../data/site';
import { breadcrumbSchema, faqSchema } from '../../lib/seo';

export function getStaticPaths() {
  return industries.map((industry) => ({
    params: { slug: industry.slug },
    props: { industry },
  }));
}

const { industry }: { industry: Industry } = Astro.props;
const relatedServices = industry.relatedServices.map((slug) => serviceMap[slug]);
const relatedCaseStudies = industry.relatedCaseStudies.map((slug) => caseStudyMap[slug]);

const structuredData = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Industries', path: '/industries/' },
    { name: industry.name, path: industryHref(industry.slug) },
  ]),
  faqSchema(industry.faq),
];
---

<Layout
  title={industry.metaTitle}
  description={industry.metaDescription}
  canonicalPath={industryHref(industry.slug)}
  structuredData={structuredData}
>
  <SiteHeader />
  <main class="bg-white text-slate-900">
    <section class="border-b-2 border-slate-100 px-6 py-20">
      <div class="mx-auto max-w-6xl">
        <Breadcrumbs
          items={[
            { href: '/', label: 'Home' },
            { href: '/industries/', label: 'Industries' },
            { href: industryHref(industry.slug), label: industry.name },
          ]}
        />
        <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">Industry focus</div>
        <h1 class="mt-6 max-w-4xl font-serif text-5xl font-black leading-tight italic md:text-7xl">
          {industry.heroTitle}
        </h1>
        <p class="mt-8 max-w-3xl text-xl leading-relaxed text-slate-600">{industry.heroDescription}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          {relatedServices.map((service) => (
            <a
              href={serviceHref(service.slug)}
              class="rounded-full border border-blue-100 bg-blue-50 px-4 py-2 text-sm font-black uppercase tracking-[0.2em] text-blue-800"
            >
              {service.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-2">
        <div class="rounded-[2rem] border-4 border-slate-900 bg-white p-8">
          <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">Where work gets stuck</div>
          <ul class="mt-6 space-y-4 text-lg leading-relaxed text-slate-700">
            {industry.painPoints.map((painPoint) => (
              <li>{painPoint}</li>
            ))}
          </ul>
        </div>
        <div class="rounded-[2rem] border-4 border-slate-200 bg-slate-50 p-8">
          <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">What automation looks like here</div>
          <ul class="mt-6 space-y-4 text-lg leading-relaxed text-slate-700">
            {industry.automations.map((automation) => (
              <li>{automation}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="border-y-2 border-slate-900 bg-slate-100 px-6 py-20">
      <div class="mx-auto max-w-6xl">
        <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">Recommended services</div>
        <h2 class="mt-6 font-serif text-4xl font-black italic md:text-5xl">
          The stack that usually fits {industry.name.toLowerCase()}
        </h2>
        <div class="mt-10 grid gap-8 md:grid-cols-2 xl:grid-cols-3">
          {relatedServices.map((service) => (
            <article class="rounded-[2rem] border-4 border-slate-200 bg-white p-8">
              <h3 class="text-2xl font-black text-slate-900">{service.name}</h3>
              <p class="mt-4 text-lg leading-relaxed text-slate-600">{service.teaser}</p>
              <a
                href={serviceHref(service.slug)}
                class="mt-6 inline-flex items-center gap-3 text-base font-black text-slate-900 transition-colors hover:text-blue-800"
              >
                Explore {service.name}
                <span aria-hidden="true">→</span>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    {relatedCaseStudies.length > 0 && (
      <section class="px-6 py-20">
        <div class="mx-auto max-w-6xl">
          <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">Related proof</div>
          <h2 class="mt-6 font-serif text-4xl font-black italic md:text-5xl">Case studies in this orbit</h2>
          <div class="mt-10 grid gap-8 lg:grid-cols-2">
            {relatedCaseStudies.map((caseStudy) => (
              <article class="rounded-[2rem] border-4 border-slate-200 bg-white p-8">
                <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">
                  {caseStudy.clientLabel} · {caseStudy.location}
                </div>
                <h3 class="mt-4 text-3xl font-black text-slate-900">{caseStudy.title}</h3>
                <p class="mt-4 text-lg leading-relaxed text-slate-600">{caseStudy.teaser}</p>
                <a
                  href={caseStudyHref(caseStudy.slug)}
                  class="mt-6 inline-flex items-center gap-3 text-base font-black text-slate-900 transition-colors hover:text-blue-800"
                >
                  Read the case study
                  <span aria-hidden="true">→</span>
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="bg-white px-6 py-20">
      <div class="mx-auto max-w-4xl">
        <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">FAQ</div>
        <h2 class="mt-6 font-serif text-4xl font-black italic md:text-5xl">Questions from {industry.name.toLowerCase()}</h2>
        <div class="mt-10 space-y-5">
          {industry.faq.map((faq) => (
            <details class="rounded-[1.75rem] border-4 border-slate-900 bg-white p-8 shadow-[10px_10px_0_0_rgba(15,23,42,1)]">
              <summary class="cursor-pointer list-none text-xl font-black text-slate-900">
                {faq.question}
              </summary>
              <p class="mt-5 text-lg leading-relaxed text-slate-600">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <SectionCta
      headline={`Want to map AI opportunities for ${industry.name.toLowerCase()}?`}
      body="Request an audit and we’ll show where lead handling, intake, and growth automation fit best for your team."
      buttonText={`Talk About ${industry.name}`}
      subject={`Caliperworks Industry Inquiry - ${industry.name}`}
    />
  </main>
  <SiteFooter />
</Layout>
