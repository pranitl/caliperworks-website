---
import Layout from '../layouts/Layout.astro';

// Date Awareness Logic
const now = new Date();
const currentYear = now.getFullYear();
const currentQuarter = Math.floor(now.getMonth() / 3) + 1;
const availabilityString = `Accepting Q${currentQuarter} ${currentYear} Audit Requests`;

// Content Integration
const hero = {
  headline: "AI that does the work, so you don't have to.",
  subheadline: "We help small businesses integrate AI into their daily operations. Not just as a chatbot, but as a team member that books calls, qualifies leads, and optimizes your marketing.",
  cta: "Get My Free Audit"
};

const inquiryMailto =
  "mailto:pranit@caliperworks.com?subject=Caliperworks%20Inquiry%20-%20Request%20a%20Free%20Audit";

const problem = {
  text: "Most business owners know AI exists, but don't know how to use it beyond a basic chat interface. You're busy running your business—HVAC, dental practice, or real estate agency. You don't have time to be an AI researcher. We bridge that gap by building tools that handle the repetitive work for you."
};

const solutions = [
  {
    title: "Process Audits",
    subtitle: "Identify your opportunities",
    description: "We map your workflow to find the exact points where AI saves time and cuts costs. It's a clear roadmap for automation."
  },
  {
    title: "Voice Agents",
    subtitle: "Your 24/7 front desk",
    description: "A digital receptionist that picks up when you're busy, qualifies leads, and books appointments directly into your calendar."
  },
  {
    title: "Growth Engine",
    subtitle: "Automated SEO & Ads",
    description: "An AI pipeline that puts you on Page 1 and hyper-optimizes your existing ad budget, tweaking bids 24/7 to get more leads for every dollar spent."
  }
];

const testimonials = [
  {
    quote: "Our monthly engaged visitors shot up by 199% and we're finally holding Page 1 rankings for our top keywords. The automated lead qualification has transformed how we handle new client intake.",
    author: "Home Care Agency in Boston",
    metrics: ["199% Visitor Increase", "Page 1 Visibility", "Voice Agent Qualified"]
  },
  {
    quote: "The ad automation hyper-optimized the budget I was already spending. I saw 25% more leads without increasing my ad spend, and the lead conversion rate jumped by 30%.",
    author: "HVAC Business Owner in Austin, TX",
    metrics: ["25% More Leads", "30% Conversion Boost", "Budget Optimized"]
  }
];

const industries = [
  { 
    name: "Home Care Agencies", 
    detail: "SEO-driven growth and automated lead qualification to help you scale caregiver recruitment and client intake seamlessly.",
    tags: ["SEO", "Ads Automation", "Voice Agent"]
  },
  { 
    name: "Dentists", 
    detail: "Ensure no appointment request or emergency call goes unanswered, even when your front desk is at capacity.",
    tags: ["Voice Agent"]
  },
  { 
    name: "Laundromats", 
    detail: "Dominate your neighborhood's pick-up and delivery market by hyper-optimizing local ad spend and search visibility.",
    tags: ["Local SEO", "Ad Budget Optimization"]
  },
  { 
    name: "HVAC & Plumbing", 
    detail: "Handling emergency calls 24/7 and booking service windows while getting more leads from your existing ad budget.",
    tags: ["Voice Agent", "SEO", "Ads Automation"]
  },
  { 
    name: "Real Estate", 
    detail: "Qualifying buyer and seller leads instantly, ensuring you only spend time on your most serious prospects.",
    tags: ["Voice Agent"]
  }
];

const faqs = [
  {
    q: "How is this different from ChatGPT?",
    a: "ChatGPT is a tool you talk to. We build systems that do work. Whether it's answering your phones or managing your SEO, our tools are integrated into your existing business flow."
  },
  {
    q: "Is it hard to set up?",
    a: "No. We handle the technical integration. You just tell us how your business works, and we build the AI to match it."
  },
  {
    q: "Is AI expensive?",
    a: "We focus on ROI. Most of our tools pay for themselves—for example, by getting more leads from the same ad budget or capturing calls that would otherwise be lost."
  },
  {
    q: "Will my customers know they're talking to an AI?",
    a: "Our voice and text agents are designed to be helpful and professional. We prioritize accuracy and a smooth experience over 'trying to trick' the customer."
  }
];
---

<Layout title="Caliperworks | Purposeful AI for Small Business">
  <div class="font-sans text-xl leading-relaxed text-slate-900 overflow-x-hidden bg-white">
    
    <!-- Navigation (Sticky & Clear) -->
    <nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b-2 border-slate-900 px-6 py-4 flex items-center justify-between">
      <div class="text-2xl font-black tracking-tighter">CALIPERWORKS</div>
      <div class="hidden lg:flex items-center space-x-10 font-bold text-base">
        <a href="#solutions" class="hover:text-blue-800 transition-colors">How We Help</a>
        <a href="#results" class="hover:text-blue-800 transition-colors">Success Stories</a>
        <a href="#expertise" class="hover:text-blue-800 transition-colors">Industries</a>
        <a href="#faq" class="hover:text-blue-800 transition-colors">FAQ</a>
        <a href={inquiryMailto} class="bg-slate-900 text-white px-8 py-3 rounded-full hover:bg-blue-800 transition-all hover:scale-105 active:scale-95 shadow-lg">Get My Free Audit</a>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative bg-white pt-12 md:pt-20 pb-24 px-6 overflow-hidden min-h-[90vh] flex items-center border-b-2 border-slate-100">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
        <div class="relative z-10">
          <div class="inline-flex items-center gap-3 px-4 py-2 bg-blue-50 border border-blue-100 rounded-full mb-8">
            <span class="w-2 h-2 bg-blue-600 rounded-full animate-pulse"></span>
            <span class="font-bold text-blue-900 text-sm tracking-tight">{availabilityString}</span>
          </div>
          <h1 class="font-serif text-6xl md:text-8xl font-black leading-tight tracking-tight mb-8 text-slate-900">
            {hero.headline}
          </h1>
          <p class="text-xl md:text-2xl text-slate-600 mb-10 max-w-xl font-medium leading-relaxed">
            {hero.subheadline}
          </p>
          <div class="flex flex-wrap gap-6">
            <a href={inquiryMailto} class="bg-blue-800 text-white text-xl md:text-2xl font-bold px-10 py-5 rounded-2xl hover:bg-slate-900 transition-all shadow-xl hover:-translate-y-1 active:translate-y-0">
              {hero.cta}
            </a>
          </div>
        </div>

        <!-- Cycling Growth Engine Graphic (Scaled Down) -->
        <div class="relative hidden lg:block scale-90 origin-right">
          <div class="absolute inset-0 bg-blue-600/[0.02] rounded-[3rem] transform -rotate-2 -z-10 border border-slate-100"></div>
          
          <div class="relative bg-white border-4 border-slate-900 p-8 rounded-[3.5rem] shadow-[20px_20px_0_0_rgba(15,23,42,1)] overflow-hidden max-w-xl mx-auto">
            <!-- Background Decorative Grid -->
            <div class="absolute inset-0 opacity-[0.05] pointer-events-none" style="background-image: linear-gradient(#94a3b8 1px, transparent 1px), linear-gradient(90deg, #94a3b8 1px, transparent 1px); background-size: 30px 30px;"></div>
            
            <div class="relative z-10 flex flex-col gap-8 min-h-[360px]">
              <!-- Central Anchor: Purposeful Automation -->
              <div class="flex justify-center pt-4">
                <div class="bg-slate-900 text-white rounded-[1.5rem] px-8 py-4 text-center shadow-xl border-2 border-slate-700">
                  <div class="text-[10px] font-black uppercase tracking-[0.4em] text-blue-400 mb-1">Caliper Core</div>
                  <div class="text-xl font-serif font-black italic">Purposeful Automation</div>
                </div>
              </div>

              <!-- Animated Connector Lines (Static CSS) -->
              <div class="absolute top-[80px] left-1/2 -translate-x-1/2 w-px h-[240px] bg-dashed-v z-0"></div>

              <!-- Cycling Content Area -->
              <div id="hero-cycler" class="relative flex-grow">
                <!-- State 1: Lead Capture (Voice) -->
                <div class="cycle-item active flex flex-col gap-6 items-center transition-all duration-700 absolute inset-0 pt-4">
                  <div class="w-full flex justify-between items-center px-4">
                    <div class="bg-white border-2 border-slate-200 p-4 rounded-xl flex items-center gap-3 shadow-sm">
                      <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                      </div>
                      <span class="text-xs font-black uppercase tracking-widest text-slate-400">Inbound Call</span>
                    </div>
                    <div class="bg-white border-2 border-slate-200 p-4 rounded-xl flex items-center gap-3 shadow-sm">
                      <span class="text-xs font-black uppercase tracking-widest text-slate-400">Qualifying...</span>
                      <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center text-emerald-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      </div>
                    </div>
                  </div>
                  <div class="mt-8 bg-emerald-50 border-2 border-emerald-500/30 p-6 rounded-2xl flex items-center gap-6 w-[90%] shadow-lg mx-auto">
                    <div class="w-12 h-12 rounded-full bg-emerald-500 flex items-center justify-center text-white shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    </div>
                    <div>
                      <div class="text-[10px] font-black uppercase text-emerald-600 tracking-widest">Lead Result</div>
                      <div class="text-xl font-serif font-black italic text-slate-800 leading-tight">Confirmed Booking</div>
                    </div>
                  </div>
                </div>

                <!-- State 2: Growth Engine (Ads/Budget Optimization) -->
                <div class="cycle-item opacity-0 translate-y-8 flex flex-col gap-6 items-center transition-all duration-700 absolute inset-0 pt-4">
                  <div class="w-full flex justify-between items-center px-4">
                    <div class="bg-white border-2 border-slate-200 p-4 rounded-xl flex items-center gap-3 shadow-sm">
                      <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      </div>
                      <span class="text-xs font-black uppercase tracking-widest text-slate-400">Current Budget</span>
                    </div>
                    <div class="bg-white border-2 border-slate-200 p-4 rounded-xl flex items-center gap-3 shadow-sm">
                      <span class="text-xs font-black uppercase tracking-widest text-slate-400">Optimizing...</span>
                      <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                      </div>
                    </div>
                  </div>
                  <div class="mt-8 bg-blue-50 border-2 border-blue-500/30 p-6 rounded-2xl flex items-center gap-6 w-[90%] shadow-lg mx-auto">
                    <div class="w-12 h-12 rounded-full bg-blue-600 flex items-center justify-center text-white shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    </div>
                    <div>
                      <div class="text-[10px] font-black uppercase text-blue-600 tracking-widest">Growth Result</div>
                      <div class="text-xl font-serif font-black italic text-slate-800 leading-tight">25% More Leads</div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Cycle Navigation Pills -->
              <div class="flex justify-center gap-3 pt-4">
                <div class="cycle-pill active w-8 h-1.5 bg-slate-900 rounded-full transition-all"></div>
                <div class="cycle-pill w-3 h-1.5 bg-slate-200 rounded-full transition-all"></div>
              </div>
            </div>
          </div>
          
          <!-- Abstract Background Glows -->
          <div class="absolute -top-10 -right-10 w-40 h-40 bg-blue-100 rounded-full blur-3xl opacity-50 -z-20"></div>
          <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-emerald-100 rounded-full blur-3xl opacity-50 -z-20"></div>
        </div>
      </div>
    </section>

    <!-- Problem Section (Zebra Stripe 1) -->
    <section class="bg-slate-100 py-32 px-6 border-y-2 border-slate-900">
      <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-20 items-center">
        <div>
          <h2 class="font-serif text-5xl font-black mb-8 leading-tight">You run the business.<br/><span class="text-blue-800">We run the AI.</span></h2>
          <div class="h-2 w-32 bg-blue-800"></div>
        </div>
        <div class="text-2xl text-slate-700 leading-relaxed border-l-4 border-blue-800 pl-8 font-medium italic">
          {problem.text}
        </div>
      </div>
    </section>

    <!-- Solutions Section -->
    <section id="solutions" class="bg-white py-32 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="mb-20 text-center">
          <h2 class="font-serif text-6xl font-black mb-6 italic">Solutions that work for you</h2>
          <p class="text-2xl text-slate-500 font-medium">No jargon. Just tools that help you do more in less time.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-10">
          {solutions.map((s) => (
            <div class="group relative bg-white border-4 border-slate-900 p-10 rounded-[2.5rem] transition-all hover:-translate-y-2 hover:shadow-[16px_16px_0_0_rgba(15,23,42,1)]">
              <span class="text-blue-600 font-black text-sm uppercase tracking-[0.2em] mb-4 block underline decoration-2 underline-offset-4">{s.subtitle}</span>
              <h3 class="font-serif text-4xl font-black mb-6 group-hover:text-blue-800 transition-colors leading-tight">{s.title}</h3>
              <p class="text-slate-600 text-xl leading-relaxed font-medium mb-10">{s.description}</p>
              
              <div class="pt-8 border-t-2 border-slate-100">
                <a href="#audit" class="inline-flex items-center gap-3 font-black text-slate-900 group-hover:text-blue-800 transition-colors">
                  Learn more
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 transform group-hover:translate-x-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Results/Testimonials (Purposeful Automation) -->
    <section id="results" class="bg-slate-900 text-white py-32 px-6 overflow-hidden relative border-y-2 border-slate-900">
      <div class="max-w-7xl mx-auto relative z-10">
        <div class="text-center mb-24">
          <h2 class="font-serif text-5xl md:text-7xl font-black mb-6 text-emerald-400 italic">Success Stories</h2>
          <p class="text-2xl text-slate-400 font-medium">Verifiable growth through purposeful automation.</p>
        </div>
        
        <div class="grid lg:grid-cols-2 gap-12">
          {testimonials.map((t) => (
            <div class="p-12 border-4 border-slate-800 rounded-[3rem] bg-slate-800/40 backdrop-blur-md relative">
              <p class="text-3xl font-serif font-black mb-10 leading-snug italic text-slate-100">
                "{t.quote}"
              </p>
              <div class="flex flex-wrap gap-3 mb-8">
                {t.metrics.map(m => (
                  <span class="bg-emerald-500/10 border-2 border-emerald-500/50 text-emerald-400 font-bold px-4 py-2 rounded-xl text-xs uppercase tracking-widest">{m}</span>
                ))}
              </div>
              <div class="text-xl font-bold text-slate-400 border-t-2 border-slate-700/50 pt-6">
                — {t.author}
              </div>
            </div>
          ))}
        </div>

        <!-- Big Stats Summary Bar -->
        <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-8 border-t-4 border-slate-800 pt-20">
          <div class="text-center">
            <div class="text-7xl font-black text-emerald-400 tracking-tighter mb-2">199%</div>
            <div class="text-sm font-black text-slate-400 uppercase tracking-widest leading-tight">Traffic Increase</div>
          </div>
          <div class="text-center">
            <div class="text-7xl font-black text-emerald-400 tracking-tighter mb-2">Page 1</div>
            <div class="text-sm font-black text-slate-400 uppercase tracking-widest leading-tight">Search Visibility</div>
          </div>
          <div class="text-center">
            <div class="text-7xl font-black text-emerald-400 tracking-tighter mb-2">25%</div>
            <div class="text-sm font-black text-slate-400 uppercase tracking-widest leading-tight">More Leads</div>
          </div>
          <div class="text-center">
            <div class="text-7xl font-black text-emerald-400 tracking-tighter mb-2">30%</div>
            <div class="text-sm font-black text-slate-400 uppercase tracking-widest leading-tight">Conversion Boost</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Industry Expertise -->
    <section id="expertise" class="bg-slate-100 py-32 px-6 border-y-2 border-slate-900">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-20 gap-8">
          <div>
            <h2 class="font-serif text-6xl font-black mb-6 italic">Expertise by Industry</h2>
            <p class="text-2xl text-slate-600 max-w-2xl font-medium leading-relaxed">Tailored systems for businesses that live in the physical world.</p>
          </div>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {industries.map((ind) => (
            <div class="bg-white border-4 border-slate-200 p-10 rounded-[2.5rem] hover:border-blue-600 transition-all shadow-sm hover:shadow-xl group flex flex-col h-full">
              <h3 class="font-black text-3xl mb-6 text-slate-900 group-hover:text-blue-800 transition-colors">{ind.name}</h3>
              <p class="text-slate-600 text-xl font-medium leading-relaxed mb-8 flex-grow">{ind.detail}</p>
              
              <div class="flex flex-wrap gap-2 pt-6 border-t border-slate-100">
                {ind.tags.map(tag => (
                  <span class="bg-blue-50 text-blue-800 text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest border border-blue-100">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section id="faq" class="bg-white py-32 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-serif text-6xl font-black text-center mb-24 italic">Common Inquiries</h2>
        <div class="space-y-10">
          {faqs.map((faq) => (
            <div class="border-4 border-slate-900 rounded-[2rem] overflow-hidden shadow-[12px_12px_0_0_rgba(15,23,42,1)] hover:shadow-none transition-all duration-300">
              <div class="bg-slate-900 text-white p-8 font-black text-2xl">
                {faq.q}
              </div>
              <div class="p-10 text-xl text-slate-700 bg-white font-medium">
                {faq.a}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section id="audit" class="bg-blue-800 text-white py-32 px-6 text-center border-t-2 border-slate-900 relative overflow-hidden">
      <div class="max-w-4xl mx-auto relative z-10">
        <h2 class="font-serif text-6xl md:text-9xl font-black mb-12 tracking-tighter italic">Ready to automate?</h2>
        <p class="text-3xl mb-16 text-blue-100 font-medium leading-relaxed">Let's find the high-impact wins in your business processes and start scaling today.</p>
        <a href={inquiryMailto} class="inline-block bg-white text-blue-900 text-4xl font-black px-20 py-10 rounded-3xl hover:scale-105 transition-transform shadow-[0_30px_90px_rgba(0,0,0,0.3)] hover:bg-slate-100 active:scale-95">
          Request My Free Audit
        </a>
      </div>
      <!-- Decorative Background Text -->
      <div class="absolute -bottom-10 -right-20 text-[20rem] font-black text-white/5 pointer-events-none select-none italic tracking-tighter">CALIPER</div>
    </section>

    <!-- Footer -->
    <footer class="bg-slate-900 text-slate-400 py-24 px-6 border-t-2 border-slate-800">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-16 mb-24">
        <div>
          <div class="text-white text-4xl font-black tracking-tighter mb-6">CALIPERWORKS</div>
          <p class="text-2xl font-medium text-slate-500 italic max-w-sm leading-snug">Purposeful automation for the real world.</p>
        </div>
        <div class="flex flex-wrap gap-16 text-xl font-bold">
          <div class="space-y-6">
            <div class="text-xs font-black text-blue-500 uppercase tracking-[0.3em] mb-4">Navigation</div>
            <a href="#solutions" class="block hover:text-white transition-colors">How We Help</a>
            <a href="#results" class="block hover:text-white transition-colors">Success Stories</a>
            <a href="#expertise" class="block hover:text-white transition-colors">Expertise</a>
          </div>
          <div class="space-y-6">
            <div class="text-xs font-black text-blue-500 uppercase tracking-[0.3em] mb-4">Contact</div>
            <a href={inquiryMailto} class="block hover:text-white transition-colors">Contact</a>
          </div>
        </div>
      </div>
      <div class="max-w-7xl mx-auto mt-20 pt-12 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center gap-8 text-sm font-bold uppercase tracking-[0.2em] opacity-30">
        <div>&copy; 2026 Caliperworks. All protocols observed.</div>
        <div class="flex gap-4">
          <div class="h-1 w-12 bg-slate-700"></div>
          <div class="h-1 w-12 bg-slate-700"></div>
          <div class="h-1 w-12 bg-slate-700"></div>
        </div>
      </div>
    </footer>

  </div>

  <script is:inline>
    // Hero Graphic Cycler
    const items = document.querySelectorAll('.cycle-item');
    const pills = document.querySelectorAll('.cycle-pill');
    let currentIndex = 0;

    function cycle() {
      // Deactivate current
      items[currentIndex].classList.remove('active');
      items[currentIndex].classList.add('opacity-0', 'translate-y-8');
      pills[currentIndex].classList.remove('active', 'w-8');
      pills[currentIndex].classList.add('w-3', 'bg-slate-200');

      // Update index
      currentIndex = (currentIndex + 1) % items.length;

      // Activate next
      items[currentIndex].classList.add('active');
      items[currentIndex].classList.remove('opacity-0', 'translate-y-8');
      pills[currentIndex].classList.add('active', 'w-8', 'bg-slate-900');
      pills[currentIndex].classList.remove('w-3', 'bg-slate-200');
    }

    setInterval(cycle, 4000);
  </script>
</Layout>

