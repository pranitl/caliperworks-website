---
import Layout from '../../layouts/Layout.astro';
import SectionCta from '../../components/SectionCta.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { caseStudies, caseStudyHref } from '../../data/site';
import { breadcrumbSchema, itemListSchema } from '../../lib/seo';

const structuredData = [
  breadcrumbSchema([{ name: 'Home', path: '/' }, { name: 'Case Studies', path: '/case-studies/' }]),
  itemListSchema('Caliperworks case studies', caseStudies.map((caseStudy) => ({ name: caseStudy.title, path: caseStudyHref(caseStudy.slug) }))),
];
---

<Layout title="Case Studies | Caliperworks" description="Review Caliperworks work across search growth, demand efficiency, lead qualification, and operational handoffs." canonicalPath="/case-studies/" structuredData={structuredData}>
  <SiteHeader />
  <main class="bg-[#fbfaf7] text-slate-950">
    <section class="border-b border-slate-200 px-6 py-20 md:py-28">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
        <div><div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Selected work</div><h1 class="mt-6 max-w-5xl text-5xl font-semibold leading-[1.02] tracking-[-0.055em] md:text-7xl">Proof tied to the condition, work, and outcome.</h1></div>
        <p class="text-lg leading-8 text-slate-600">Measured business results stay distinct from completed plans and implementation milestones. Each example keeps its own context.</p>
      </div>
    </section>
    <section class="px-6 py-20 md:py-28">
      <div class="mx-auto max-w-7xl border-t border-slate-300">
        {caseStudies.map((caseStudy, index) => (
          <article class="grid gap-8 border-b border-slate-300 py-10 lg:grid-cols-[5rem_0.8fr_1.2fr]">
            <div class="text-sm font-semibold text-slate-400">0{index + 1}</div>
            <div><div class="text-xs font-bold uppercase tracking-[0.18em] text-blue-700">{caseStudy.clientLabel} · {caseStudy.location}</div><h2 class="mt-4 text-3xl font-semibold tracking-[-0.035em]">{caseStudy.title}</h2></div>
            <div><p class="text-lg leading-8 text-slate-600">{caseStudy.heroDescription}</p><div class="mt-6 flex flex-wrap gap-x-8 gap-y-3">{caseStudy.results.map((result) => <div><span class="font-semibold text-slate-950">{result.value}</span> <span class="text-sm text-slate-500">{result.label}</span></div>)}</div><a href={caseStudyHref(caseStudy.slug)} class="mt-6 inline-flex text-sm font-bold text-blue-800">Read the case study →</a></div>
          </article>
        ))}
      </div>
    </section>
    <SectionCta headline="See where the closest relevant result begins." body="Request a gap review and we will connect your current constraint to the most relevant prior work without treating another company’s result as a promise." />
  </main>
  <SiteFooter />
</Layout>
