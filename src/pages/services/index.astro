---
import Layout from '../../layouts/Layout.astro';
import SectionCta from '../../components/SectionCta.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { pricingHref, serviceHref, services } from '../../data/site';
import { breadcrumbSchema, itemListSchema } from '../../lib/seo';

const orderedServices = [
  services.find((service) => service.slug === 'seo-and-ads-automation'),
  services.find((service) => service.slug === 'voice-agents'),
  services.find((service) => service.slug === 'ai-process-audits'),
].filter((service) => service !== undefined);

const structuredData = [
  breadcrumbSchema([{ name: 'Home', path: '/' }, { name: 'Services', path: '/services/' }]),
  itemListSchema('Caliperworks services', services.map((service) => ({ name: service.name, path: serviceHref(service.slug) }))),
];
---

<Layout
  title="SEO, Voice Coverage, and Workflow Services | Caliperworks"
  description="Explore packaged local SEO execution and custom-scoped voice coverage, ads workflows, and operational automation for service businesses."
  canonicalPath="/services/"
  structuredData={structuredData}
>
  <SiteHeader />
  <main class="bg-[#fbfaf7] text-slate-950">
    <section class="border-b border-slate-200 px-6 py-20 md:py-28">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
        <div>
          <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Services</div>
          <h1 class="mt-6 max-w-5xl text-5xl font-semibold leading-[1.02] tracking-[-0.055em] md:text-7xl">One path from qualified demand to the next useful action.</h1>
        </div>
        <p class="text-lg leading-8 text-slate-600">SEO execution is packaged by monthly output. Voice agents, ads workflows, and operational automation are custom-scoped around the system your team already uses.</p>
      </div>
    </section>

    <section class="px-6 py-20 md:py-28">
      <div class="mx-auto max-w-7xl border-t border-slate-300">
        {orderedServices.map((service, index) => (
          <article class="grid gap-8 border-b border-slate-300 py-12 lg:grid-cols-[5rem_0.8fr_1.2fr]">
            <div class="text-sm font-semibold text-slate-400">0{index + 1}</div>
            <div>
              <div class="text-xs font-bold uppercase tracking-[0.2em] text-blue-700">{service.slug === 'seo-and-ads-automation' ? 'Packaged execution' : 'Custom scope'}</div>
              <h2 class="mt-4 text-3xl font-semibold tracking-[-0.035em]">{service.name}</h2>
            </div>
            <div>
              <p class="text-lg leading-8 text-slate-600">{service.summary}</p>
              <div class="mt-6 flex flex-wrap gap-5">
                <a href={serviceHref(service.slug)} class="text-sm font-bold text-blue-800">Explore the service →</a>
                {service.slug === 'seo-and-ads-automation' && <a href={pricingHref(service.slug)} class="text-sm font-bold text-slate-700">View pricing →</a>}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <SectionCta headline="Choose the constraint before choosing the service." body="Request a gap review and we will determine whether visibility, call coverage, paid-demand flow, or an operational handoff should come first." />
  </main>
  <SiteFooter />
</Layout>
