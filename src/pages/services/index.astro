---
import Layout from '../../layouts/Layout.astro';
import SectionCta from '../../components/SectionCta.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import {
  caseStudies,
  caseStudyHref,
  pricingHref,
  serviceHref,
  services,
} from '../../data/site';
import { breadcrumbSchema, itemListSchema } from '../../lib/seo';

const serviceCards = [
  services.find((service) => service.slug === 'seo-and-ads-automation'),
  services.find((service) => service.slug === 'voice-agents'),
  services.find((service) => service.slug === 'ai-process-audits'),
].filter((service) => service !== undefined);

const structuredData = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Services', path: '/services/' },
  ]),
  itemListSchema(
    'Caliperworks service pages',
    services.map((service) => ({
      name: service.name,
      path: serviceHref(service.slug),
    }))
  ),
];
---

<Layout
  title="Local SEO and AI Services for Service Businesses | Caliperworks"
  description="Explore Caliperworks services for local SEO execution, growth assets, AI process audits, voice agents, and ads automation for small businesses."
  canonicalPath="/services/"
  structuredData={structuredData}
>
  <SiteHeader />
  <main class="bg-white text-slate-900">
    <section class="border-b-2 border-slate-100 px-6 py-20">
      <div class="mx-auto max-w-7xl">
        <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">Services</div>
        <h1 class="mt-6 max-w-4xl font-serif text-5xl font-black leading-tight italic md:text-7xl">
          Local SEO execution, voice coverage, and workflow cleanup for service businesses
        </h1>
        <p class="mt-8 max-w-3xl text-xl leading-relaxed text-slate-600">
          Search is often the clearest growth lever: better service pages, location coverage, landing pages,
          and conversion paths. Caliperworks pairs that SEO execution with voice agents, ads workflows, and
          operational cleanup when the audit shows those systems are the next constraint.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="/pricing/"
            class="inline-flex items-center justify-center rounded-2xl bg-slate-900 px-8 py-4 text-base font-black text-white transition-colors hover:bg-blue-800"
          >
            View Pricing
          </a>
          <a
            href={serviceHref('ai-process-audits')}
            class="inline-flex items-center justify-center rounded-2xl border-2 border-slate-900 px-8 py-4 text-base font-black text-slate-900 transition-colors hover:border-blue-800 hover:text-blue-800"
          >
            Start with a Free Audit
          </a>
        </div>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-3">
        {serviceCards.map((service) => (
          <article
            class:list={[
              'flex h-full flex-col rounded-[2.5rem] border-4 p-10 shadow-sm',
              service.slug === 'seo-and-ads-automation'
                ? 'border-blue-800 bg-blue-800 text-white shadow-[14px_14px_0_0_rgba(15,23,42,1)]'
                : 'border-slate-900 bg-white text-slate-900',
            ]}
          >
            <div class:list={['text-sm font-black uppercase tracking-[0.25em]', service.slug === 'seo-and-ads-automation' ? 'text-blue-100' : 'text-blue-700']}>
              {service.slug === 'seo-and-ads-automation' ? 'Featured service' : service.shortLabel}
            </div>
            <h2 class="mt-4 font-serif text-4xl font-black leading-tight">{service.name}</h2>
            <p class:list={['mt-6 text-lg leading-relaxed', service.slug === 'seo-and-ads-automation' ? 'text-blue-50' : 'text-slate-600']}>{service.summary}</p>
            <ul class:list={['mt-8 space-y-3 text-sm font-semibold', service.slug === 'seo-and-ads-automation' ? 'text-white' : 'text-slate-700']}>
              {service.deliverables.map((deliverable) => (
                <li class:list={['rounded-xl px-4 py-3', service.slug === 'seo-and-ads-automation' ? 'bg-white/10' : 'bg-slate-50']}>{deliverable}</li>
              ))}
            </ul>
            <div class="mt-8 flex flex-wrap gap-4">
              <a
                href={serviceHref(service.slug)}
                class:list={[
                  'inline-flex items-center justify-center rounded-2xl border-2 px-5 py-3 text-base font-black transition-colors',
                  service.slug === 'seo-and-ads-automation'
                    ? 'border-white text-white hover:bg-white hover:text-blue-900'
                    : 'border-slate-900 text-slate-900 hover:border-blue-800 hover:text-blue-800',
                ]}
              >
                Learn more
              </a>
              <a
                href={service.slug === 'ai-process-audits' ? serviceHref(service.slug) : pricingHref(service.slug)}
                class:list={[
                  'inline-flex items-center justify-center rounded-2xl px-5 py-3 text-base font-black transition-colors',
                  service.slug === 'seo-and-ads-automation'
                    ? 'bg-white text-blue-900 hover:bg-slate-100'
                    : '',
                  service.slug === 'ai-process-audits'
                    ? 'bg-slate-900 text-white hover:bg-blue-800'
                    : service.slug === 'seo-and-ads-automation'
                      ? ''
                      : 'bg-blue-800 text-white hover:bg-slate-900',
                ]}
              >
                {service.slug === 'ai-process-audits' ? 'Request the free audit' : 'See pricing'}
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="border-y-2 border-slate-900 bg-slate-100 px-6 py-20">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[1fr_1.1fr]">
        <div>
          <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">How to choose</div>
          <h2 class="mt-6 font-serif text-4xl font-black leading-tight md:text-5xl">
            Start with the audit when the bottleneck is unclear.
          </h2>
        </div>
        <div class="space-y-4 text-lg leading-relaxed text-slate-700">
          <p>If visibility is the constraint, packaged SEO execution is usually the cleanest first move: service pages, location pages, growth assets, and existing-page optimization.</p>
          <p>If you already know phone coverage or qualification is the issue, voice agents may be the first implementation path.</p>
          <p>
            If ad spend is already running, the SEO and ads path can also improve landing-page coverage, budget efficiency, and follow-up quality.
          </p>
          <p>The audit is free, so if the bottleneck is still fuzzy, that is the lowest-friction place to decide what should come first.</p>
        </div>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
          <div>
            <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">Proof</div>
            <h2 class="mt-6 font-serif text-4xl font-black italic md:text-5xl">Related case studies</h2>
          </div>
          <a
            href="/case-studies/"
            class="inline-flex items-center gap-3 text-base font-black text-slate-900 transition-colors hover:text-blue-800"
          >
            View all case studies
            <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="mt-10 grid gap-8 lg:grid-cols-2">
          {caseStudies.map((caseStudy) => (
            <article class="rounded-[2rem] border-4 border-slate-200 bg-white p-8">
              <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">
                {caseStudy.clientLabel} · {caseStudy.location}
              </div>
              <h3 class="mt-4 text-3xl font-black text-slate-900">{caseStudy.title}</h3>
              <p class="mt-4 text-lg leading-relaxed text-slate-600">{caseStudy.teaser}</p>
              <a
                href={caseStudyHref(caseStudy.slug)}
                class="mt-6 inline-flex items-center gap-3 text-base font-black text-slate-900 transition-colors hover:text-blue-800"
              >
                Read this case study
                <span aria-hidden="true">→</span>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <SectionCta
      headline="Need to choose the right starting point?"
      body="The free process audit is designed to show which service should come first based on your current workflow gaps, follow-up friction, and marketing goals."
      primaryCta={{ kind: 'mailto', label: 'Start with a Free Audit', subject: 'Caliperworks Services Inquiry' }}
      secondarySubject="Caliperworks Services Inquiry"
    />
  </main>
  <SiteFooter />
</Layout>
