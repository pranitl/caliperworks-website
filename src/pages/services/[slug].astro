---
import type { Service } from '../../data/site';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionCta from '../../components/SectionCta.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import Layout from '../../layouts/Layout.astro';
import {
  caseStudyHref,
  caseStudyMap,
  industryHref,
  industryMap,
  pricingHref,
  serviceHref,
  services,
} from '../../data/site';
import { breadcrumbSchema, faqSchema } from '../../lib/seo';

export function getStaticPaths() {
  return services.map((service) => ({ params: { slug: service.slug }, props: { service } }));
}

const { service }: { service: Service } = Astro.props;
const relatedIndustries = service.relatedIndustries.map((slug) => industryMap[slug]);
const relatedCaseStudies = service.relatedCaseStudies.map((slug) => caseStudyMap[slug]);
const isPackaged = service.slug === 'seo-and-ads-automation';
const structuredData = [
  breadcrumbSchema([{ name: 'Home', path: '/' }, { name: 'Services', path: '/services/' }, { name: service.name, path: serviceHref(service.slug) }]),
  faqSchema(service.faq),
];
---

<Layout title={service.metaTitle} description={service.metaDescription} canonicalPath={serviceHref(service.slug)} structuredData={structuredData}>
  <SiteHeader />
  <main class="bg-[#fbfaf7] text-slate-950">
    <section class="border-b border-slate-200 px-6 py-16 md:py-24">
      <div class="mx-auto max-w-7xl">
        <Breadcrumbs items={[{ href: '/', label: 'Home' }, { href: '/services/', label: 'Services' }, { href: serviceHref(service.slug), label: service.name }]} />
        <div class="mt-10 grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
          <div>
            <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">{isPackaged ? 'Packaged SEO execution' : 'Custom-scoped service'}</div>
            <h1 class="mt-6 max-w-4xl text-5xl font-semibold leading-[1.02] tracking-[-0.055em] md:text-7xl">{service.heroTitle}</h1>
            <p class="mt-7 max-w-2xl text-xl leading-8 text-slate-600">{service.heroDescription}</p>
          </div>
          <div class="border-l border-slate-300 pl-7">
            <div class="text-xs font-bold uppercase tracking-[0.18em] text-slate-400">How it is scoped</div>
            <p class="mt-4 text-xl leading-8 text-slate-700">{isPackaged ? 'Choose a published monthly execution pace after the setup and opportunity review.' : 'Scope the implementation after reviewing the workflow, rules, integrations, handoffs, and support needs.'}</p>
            <a href={isPackaged ? pricingHref(service.slug) : `mailto:pranit@caliperworks.com?subject=${encodeURIComponent(`Caliperworks Gap Review - ${service.name}`)}`} class="mt-6 inline-flex text-sm font-bold text-blue-800">{isPackaged ? 'View SEO pricing' : 'Request a gap review'} →</a>
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 py-20 md:py-28">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.72fr_1.28fr]">
        <div><div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">The constraint</div><h2 class="mt-5 text-4xl font-semibold tracking-[-0.04em]">What usually creates the need.</h2></div>
        <div class="border-t border-slate-300">{service.problems.map((problem, index) => <div class="grid gap-4 border-b border-slate-300 py-6 sm:grid-cols-[4rem_1fr]"><div class="text-sm font-semibold text-blue-700">0{index + 1}</div><p class="text-lg leading-8 text-slate-700">{problem}</p></div>)}</div>
      </div>
    </section>

    <section class="border-y border-slate-200 bg-[#f2f6fb] px-6 py-20 md:py-24">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-12 lg:grid-cols-[0.72fr_1.28fr]">
          <div><div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">What ships</div><h2 class="mt-5 text-4xl font-semibold tracking-[-0.04em]">A defined implementation path.</h2></div>
          <div class="grid gap-px border-y border-slate-300 bg-slate-300 md:grid-cols-3">{service.deliverables.map((deliverable, index) => <div class="bg-[#f2f6fb] p-7"><div class="text-sm font-semibold text-blue-700">0{index + 1}</div><p class="mt-6 text-lg leading-8 text-slate-700">{deliverable}</p></div>)}</div>
        </div>
      </div>
    </section>

    <section class="px-6 py-20 md:py-28">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-2">
        <div>
          <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Intended outcomes</div>
          <div class="mt-5 border-t border-slate-300">{service.outcomes.map((outcome) => <div class="border-b border-slate-300 py-5 text-lg leading-8 text-slate-700">{outcome}</div>)}</div>
        </div>
        <div>
          <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Where it tends to fit</div>
          <div class="mt-5 border-t border-slate-300">{relatedIndustries.map((industry) => <a href={industryHref(industry.slug)} class="grid grid-cols-[0.7fr_1.3fr] gap-5 border-b border-slate-300 py-5"><span class="font-semibold">{industry.name}</span><span class="text-slate-600">{industry.teaser}</span></a>)}</div>
        </div>
      </div>
    </section>

    {relatedCaseStudies.length > 0 && <section class="border-y border-slate-200 bg-white px-6 py-20"><div class="mx-auto max-w-7xl"><div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Related proof</div><div class="mt-7 grid gap-8 md:grid-cols-2">{relatedCaseStudies.map((caseStudy) => <article class="border-t border-slate-300 pt-6"><h2 class="text-2xl font-semibold">{caseStudy.title}</h2><p class="mt-3 leading-7 text-slate-600">{caseStudy.teaser}</p><a href={caseStudyHref(caseStudy.slug)} class="mt-4 inline-flex text-sm font-bold text-blue-800">Read the case study →</a></article>)}</div></div></section>}

    <section class="px-6 py-20"><div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.72fr_1.28fr]"><div><div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">FAQ</div><h2 class="mt-5 text-4xl font-semibold tracking-[-0.04em]">Questions about {service.name.toLowerCase()}.</h2></div><div class="border-t border-slate-300">{service.faq.map((faq) => <details class="border-b border-slate-300 py-6"><summary class="cursor-pointer list-none text-xl font-semibold">{faq.question}</summary><p class="mt-4 text-lg leading-8 text-slate-600">{faq.answer}</p></details>)}</div></div></section>

    <SectionCta headline="See whether this is the first constraint worth fixing." body="Request a gap review and we will recommend the appropriate packaged SEO pace, custom implementation path, or a clear reason to wait." />
  </main>
  <SiteFooter />
</Layout>
