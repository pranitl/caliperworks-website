---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Caliperworks | The AI Growth Engine">
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Space+Mono:wght@400;700&display=swap');

    :root {
      --electric-blue: #2D5BFF;
      --vibrant-orange: #FF4D00;
      --bg-grey: #E5E5E5;
      --text-black: #1A1A1A;
    }

    body {
      background-color: var(--bg-grey);
      color: var(--text-black);
      font-family: 'Space Mono', monospace;
      overflow-x: hidden;
    }

    h1, h2, h3, .display-font {
      font-family: 'Syne', sans-serif;
      text-transform: uppercase;
      line-height: 0.9;
    }

    .stat-outline {
      -webkit-text-stroke: 1px var(--text-black);
      color: transparent;
    }

    .marquee {
      display: flex;
      overflow: hidden;
      user-select: none;
      gap: 2rem;
    }

    .marquee-content {
      flex-shrink: 0;
      display: flex;
      justify-content: space-around;
      min-width: 100%;
      gap: 2rem;
      animation: scroll 20s linear infinite;
    }

    @keyframes scroll {
      from { transform: translateX(0); }
      to { transform: translateX(calc(-100% - 2rem)); }
    }

    .grid-mesh {
      background-image: radial-gradient(var(--text-black) 1px, transparent 1px);
      background-size: 40px 40px;
      opacity: 0.05;
    }

    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: all 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <main class="relative">
    <!-- Background Grid -->
    <div class="fixed inset-0 grid-mesh pointer-events-none -z-10"></div>

    <!-- Navigation -->
    <nav class="sticky top-0 z-50 mix-blend-difference px-6 py-4 flex justify-between items-center text-white">
      <div class="display-font text-2xl font-extrabold tracking-tighter">CALIPERWORKS</div>
      <a href="#audit" class="bg-[var(--electric-blue)] px-6 py-2 font-bold hover:scale-105 transition-transform">GET AUDIT</a>
    </nav>

    <!-- Hero Section -->
    <section class="min-h-screen flex flex-col justify-center px-6 pt-20 relative overflow-hidden">
      <div class="absolute top-1/4 right-0 w-1/3 h-1/2 bg-[var(--electric-blue)] opacity-10 blur-[120px] rounded-full -z-10"></div>
      
      <div class="max-w-7xl mx-auto w-full relative">
        <div class="text-[10vw] font-extrabold mb-8 tracking-tighter leading-none reveal" id="hero-title">
          AI THAT <span class="text-[var(--electric-blue)] italic">DOES</span> THE WORK.
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
          <div class="lg:col-span-7 reveal" style="transition-delay: 0.2s">
            <p class="text-xl md:text-2xl leading-relaxed max-w-2xl border-l-4 border-[var(--electric-blue)] pl-6">
              We help small businesses integrate AI into their daily operations. Not just as a chatbot, but as a team member that books calls, qualifies leads, and optimizes your marketing.
            </p>
            <div class="mt-12 flex flex-wrap gap-6">
              <a href="#audit" class="display-font text-2xl font-bold bg-[var(--text-black)] text-white px-10 py-5 hover:bg-[var(--electric-blue)] transition-colors group">
                GET AN AI AUDIT <span class="inline-block group-hover:translate-x-2 transition-transform">→</span>
              </a>
            </div>
          </div>
          
          <div class="lg:col-span-5 relative reveal" style="transition-delay: 0.4s">
            <!-- Impact Stats Hero -->
            <div class="relative bg-white p-8 border-4 border-black shadow-[12px_12px_0px_0px_rgba(45,91,255,1)]">
              <div class="text-8xl font-black display-font leading-none mb-2">+200%</div>
              <div class="text-sm font-bold uppercase tracking-widest text-neutral-500">Engaged Traffic</div>
              <div class="my-6 border-t border-neutral-200"></div>
              <div class="text-8xl font-black display-font leading-none mb-2">+20%</div>
              <div class="text-sm font-bold uppercase tracking-widest text-neutral-500">More Leads</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Marquee -->
    <div class="py-12 bg-black text-white overflow-hidden rotate-[-2deg] scale-105 my-20 border-y-4 border-[var(--electric-blue)]">
      <div class="marquee">
        <div class="marquee-content display-font text-4xl font-extrabold italic whitespace-nowrap">
          <span>HVAC AUTOMATION</span>
          <span>DENTAL SCHEDULING</span>
          <span>REAL ESTATE LEADS</span>
          <span>SEO ENGINE</span>
          <span>VOICE AGENTS</span>
          <span>ROI FOCUSED</span>
          <span>24/7 FRONT DESK</span>
        </div>
        <div class="marquee-content display-font text-4xl font-extrabold italic whitespace-nowrap" aria-hidden="true">
          <span>HVAC AUTOMATION</span>
          <span>DENTAL SCHEDULING</span>
          <span>REAL ESTATE LEADS</span>
          <span>SEO ENGINE</span>
          <span>VOICE AGENTS</span>
          <span>ROI FOCUSED</span>
          <span>24/7 FRONT DESK</span>
        </div>
      </div>
    </div>

    <!-- The Problem Section -->
    <section class="py-32 px-6 bg-white border-y-4 border-black relative">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-start">
          <div class="reveal">
            <h2 class="text-6xl md:text-8xl font-extrabold mb-12 tracking-tighter">THE <br/><span class="text-[var(--electric-blue)]">GAP</span></h2>
            <div class="space-y-6 text-lg">
              <p>Most business owners know AI exists, but don't know how to use it beyond a basic chat interface.</p>
              <p>You're busy running your business—HVAC, dental practice, or real estate agency. You don't have time to be an AI researcher.</p>
              <div class="h-20 w-1 bg-[var(--electric-blue)]"></div>
              <p class="font-bold text-2xl uppercase tracking-tighter">We bridge that gap by building tools that handle the repetitive work for you.</p>
            </div>
          </div>
          <div class="relative reveal" style="transition-delay: 0.3s">
            <div class="aspect-square bg-neutral-100 border-4 border-black relative overflow-hidden group">
              <div class="absolute inset-0 bg-[var(--electric-blue)] opacity-0 group-hover:opacity-10 transition-opacity"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="text-[20vw] font-black stat-outline opacity-20 group-hover:scale-110 transition-transform duration-700">?</div>
              </div>
              <div class="absolute bottom-8 left-8 right-8">
                <div class="bg-black text-white p-6 font-bold uppercase tracking-widest text-sm">
                  AI researcher is not your job title. <br/>Running your business is.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Solutions Section -->
    <section class="py-32 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-end mb-24 gap-8">
          <h2 class="text-7xl md:text-9xl font-extrabold tracking-tighter reveal">THE <br/><span class="text-[var(--electric-blue)]">ENGINE</span></h2>
          <p class="max-w-md text-right reveal" style="transition-delay: 0.2s">Custom-built systems designed to capture leads, book clients, and dominate your market while you sleep.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border-4 border-black bg-black">
          <!-- Solution 1 -->
          <div class="bg-white p-12 border-b-4 md:border-b-0 md:border-r-4 border-black reveal group hover:bg-[var(--electric-blue)] hover:text-white transition-colors">
            <div class="text-4xl font-black mb-8">01/</div>
            <h3 class="text-4xl font-extrabold mb-6">AI Audits</h3>
            <p class="mb-8 opacity-80">We identify exactly where AI can save you time and increase your revenue. It's a clear roadmap for automation.</p>
            <div class="text-sm font-bold uppercase tracking-widest">Find the Wins</div>
          </div>

          <!-- Solution 2 -->
          <div class="bg-white p-12 border-b-4 md:border-b-0 md:border-r-4 border-black reveal group hover:bg-[var(--electric-blue)] hover:text-white transition-colors" style="transition-delay: 0.2s">
            <div class="text-4xl font-black mb-8">02/</div>
            <h3 class="text-4xl font-extrabold mb-6">Voice Agents</h3>
            <p class="mb-8 opacity-80">Stop missing calls. Our agents answer 24/7, qualify prospects, and book directly into your calendar.</p>
            <div class="text-sm font-bold uppercase tracking-widest">Your 24/7 Front Desk</div>
          </div>

          <!-- Solution 3 -->
          <div class="bg-white p-12 reveal group hover:bg-[var(--electric-blue)] hover:text-white transition-colors" style="transition-delay: 0.4s">
            <div class="text-4xl font-black mb-8">03/</div>
            <h3 class="text-4xl font-extrabold mb-6">Growth SEM</h3>
            <p class="mb-8 opacity-80">Rank in ChatGPT and Google AI. 200% increase in monthly visitors and 20% more leads with optimized spend.</p>
            <div class="text-sm font-bold uppercase tracking-widest">Real Growth Engine</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Industry Expertise -->
    <section class="py-32 bg-[var(--text-black)] text-white px-6">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-5xl md:text-8xl font-extrabold tracking-tighter mb-20 reveal">BUILT FOR THE <span class="text-[var(--electric-blue)]">REAL WORLD</span></h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
          {[
            { title: "HOME CARE", desc: "Scheduling & client inquiries." },
            { title: "HVAC & PLUMBING", desc: "Emergency calls & booking windows." },
            { title: "LAUNDROMATS", desc: "Pick-up & delivery logistics." },
            { title: "DENTISTS", desc: "No-shows & automated reminders." },
            { title: "REAL ESTATE", desc: "Instantly qualify buyer/seller leads." }
          ].map((item, i) => (
            <div class="border-2 border-white/20 p-8 hover:border-[var(--electric-blue)] transition-colors group reveal" style={`transition-delay: ${i * 0.1}s`}>
              <div class="h-2 w-full bg-white/10 mb-8 overflow-hidden">
                <div class="h-full bg-[var(--electric-blue)] w-0 group-hover:w-full transition-all duration-700"></div>
              </div>
              <h4 class="display-font text-2xl font-bold mb-4">{item.title}</h4>
              <p class="text-sm opacity-60 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-32 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-6xl font-extrabold tracking-tighter mb-20 text-center reveal">DEBUNKING THE <span class="text-[var(--electric-blue)] italic">MYTHS</span></h2>
        
        <div class="space-y-4">
          {[
            { 
              q: "How is this different from ChatGPT?", 
              a: "ChatGPT is a tool you talk to. We build systems that DO WORK. Whether it's answering your phones or managing your SEO, our tools are integrated into your existing business flow." 
            },
            { 
              q: "Is it hard to set up?", 
              a: "No. We handle the technical integration. You just tell us how your business works, and we build the AI to match it." 
            },
            { 
              q: "Is AI expensive?", 
              a: "We focus on ROI. Most of our tools pay for themselves by saving hours of manual work or capturing leads that would otherwise be lost." 
            },
            { 
              q: "Will my customers know they're talking to an AI?", 
              a: "Our agents are designed to be professional. We prioritize accuracy and a smooth experience over trying to trick anyone." 
            }
          ].map((faq, i) => (
            <div class="border-4 border-black bg-white reveal" style={`transition-delay: ${i * 0.1}s`}>
              <details class="group">
                <summary class="flex justify-between items-center p-8 cursor-pointer list-none">
                  <span class="text-2xl font-bold uppercase tracking-tight">{faq.q}</span>
                  <span class="text-4xl group-open:rotate-45 transition-transform">+</span>
                </summary>
                <div class="px-8 pb-8 text-lg border-t-2 border-neutral-100 pt-6">
                  {faq.a}
                </div>
              </details>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA / Footer Area -->
    <section id="audit" class="py-32 px-6 bg-[var(--electric-blue)] text-white overflow-hidden relative">
      <div class="absolute top-0 left-0 w-full h-full grid-mesh opacity-20"></div>
      
      <div class="max-w-7xl mx-auto relative z-10 text-center">
        <h2 class="text-[12vw] font-black leading-none mb-12 tracking-tighter reveal">READY FOR <br/>THE WIN?</h2>
        <div class="flex flex-col items-center gap-12">
          <p class="text-2xl max-w-2xl reveal" style="transition-delay: 0.2s">Get your AI Audit today and find out exactly how much time and revenue you're leaving on the table.</p>
          <a href="#" class="bg-white text-black px-12 py-8 text-4xl font-black display-font hover:scale-105 transition-transform reveal group" style="transition-delay: 0.4s">
            BOOK AN AUDIT NOW <span class="inline-block group-hover:translate-x-4 transition-transform">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-black text-white py-20 px-6 border-t-4 border-[var(--electric-blue)]">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-20">
        <div>
          <div class="display-font text-4xl font-black mb-8 tracking-tighter">CALIPERWORKS</div>
          <p class="text-xl opacity-60 max-w-sm">AI for the real world. Automating the growth of small businesses across the nation.</p>
        </div>
        <div class="grid grid-cols-2 gap-12">
          <div>
            <div class="font-bold uppercase tracking-widest text-sm mb-6 text-[var(--electric-blue)]">Navigation</div>
            <ul class="space-y-4">
              <li><a href="#" class="hover:text-[var(--electric-blue)] transition-colors">GET STARTED</a></li>
              <li><a href="#" class="hover:text-[var(--electric-blue)] transition-colors">CONTACT</a></li>
              <li><a href="#" class="hover:text-[var(--electric-blue)] transition-colors">PRIVACY</a></li>
            </ul>
          </div>
          <div>
            <div class="font-bold uppercase tracking-widest text-sm mb-6 text-[var(--electric-blue)]">Social</div>
            <ul class="space-y-4">
              <li><a href="#" class="hover:text-[var(--electric-blue)] transition-colors">LINKEDIN</a></li>
              <li><a href="#" class="hover:text-[var(--electric-blue)] transition-colors">TWITTER</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="max-w-7xl mx-auto mt-20 pt-8 border-t border-white/10 text-sm opacity-40">
        &copy; {new Date().getFullYear()} CALIPERWORKS. ALL RIGHTS RESERVED.
      </div>
    </footer>
  </main>

  <script>
    // Intersection Observer for scroll animations
    const observerOptions = {
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal').forEach((el) => {
      observer.observe(el);
    });
  </script>
</Layout>
