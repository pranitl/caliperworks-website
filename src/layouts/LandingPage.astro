---
import CalTriggerButton from '../components/CalTriggerButton.astro';
import Layout from './Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { createMailto, industryHref, serviceHref } from '../data/site';

const now = new Date();
const currentYear = now.getFullYear();
const currentQuarter = Math.floor(now.getMonth() / 3) + 1;
const availabilityString = `Accepting Q${currentQuarter} ${currentYear} audit requests`;

const inquiryMailto = createMailto();

const hero = {
  headline: 'AI process audits that show where automation actually fits.',
  subheadline:
    'Caliperworks maps the gaps across intake, phone coverage, search visibility, ad workflows, and follow-up so service businesses can prioritize the right next move instead of buying isolated AI tools.',
  cta: 'Schedule Discovery Call',
};

const auditAreas = [
  {
    title: 'Calls and intake',
    detail: 'Spot where inquiries get missed, delayed, or depend too heavily on one person.',
  },
  {
    title: 'Search and content',
    detail: 'See whether visibility gaps, weak service pages, or local coverage are slowing demand.',
  },
  {
    title: 'Ads and landing pages',
    detail: 'Find where spend is active but conversion paths and follow-up are still leaking.',
  },
  {
    title: 'Routing and follow-up',
    detail: 'Map the handoffs between phone, inbox, CRM, scheduling, and staff ownership.',
  },
];

const auditFindings = [
  'Missed handoffs',
  'Thin service coverage',
  'Manual follow-up',
  'After-hours gaps',
  'Unclear ownership',
  'Underused ad spend',
];

const rolloutPaths = [
  {
    title: 'AI Process Audits',
    detail: 'Map the workflow and rank what to change first.',
    href: serviceHref('ai-process-audits'),
  },
  {
    title: 'Voice Agents',
    detail: 'Implement when phone coverage or qualification is the real bottleneck.',
    href: serviceHref('voice-agents'),
  },
  {
    title: 'SEO and Ads Automation',
    detail: 'Prioritize when visibility, landing pages, or budget efficiency are the leak.',
    href: serviceHref('seo-and-ads-automation'),
  },
];

const solutions = [
  {
    title: 'AI Process Audit',
    subtitle: 'Discovery before deployment',
    description:
      'We review intake, marketing, routing, follow-up, and handoffs to find the gaps worth fixing first.',
    href: serviceHref('ai-process-audits'),
    linkLabel: 'See audit scope',
  },
  {
    title: 'Voice and Intake Systems',
    subtitle: 'When coverage is the gap',
    description:
      'If the audit shows calls, triage, booking, or front-desk load is the real issue, we design voice and intake workflows around your rules.',
    href: serviceHref('voice-agents'),
    linkLabel: 'See voice-agent use cases',
  },
  {
    title: 'Search, Ads, and Workflow Automation',
    subtitle: 'When demand or ops are the gap',
    description:
      'If the bottleneck sits in visibility, budget efficiency, routing, or manual follow-up, we implement the right search, ad, or workflow changes.',
    href: serviceHref('seo-and-ads-automation'),
    linkLabel: 'See growth and ops paths',
  },
];

const testimonials = [
  {
    quote:
      'Caliperworks helped us see where SEO and intake were disconnected. We left with a clearer plan, better search visibility, and a cleaner way to handle new inquiries.',
    author: 'Owner, home care agency',
    location: 'Boston',
    metrics: ['199% engaged traffic', 'Page 1 visibility', 'Cleaner intake'],
  },
  {
    quote:
      'Caliperworks helped us tighten phone coverage and follow-up without making the front desk feel replaced. The handoff is much cleaner when patients call during lunch or after hours.',
    author: 'Owner, dental practice',
    location: 'Austin, TX',
    metrics: ['Lunch-hour coverage', 'After-hours intake', 'Clearer handoff'],
  },
  {
    quote:
      'Caliperworks tightened both our ad workflow and lead qualification process. We got more from the budget we already had without adding more admin work for the team.',
    author: 'Owner, HVAC company',
    location: 'Austin, TX',
    metrics: ['25% more leads', '30% conversion lift', 'Same budget'],
  },
];

const industries = [
  {
    name: 'Home Care Agencies',
    detail:
      'Use the audit to connect caregiver recruitment, client intake, SEO, and qualification workflows.',
    tags: ['Process audit', 'SEO', 'Voice agent'],
    href: industryHref('home-care-agencies'),
  },
  {
    name: 'Dentists',
    detail:
      'Audit where phone coverage, patient intake, and front-desk follow-up break down before automating.',
    tags: ['Process audit', 'Voice agent'],
    href: industryHref('dentists'),
  },
  {
    name: 'Laundromats',
    detail:
      'Find whether local search, pickup and delivery demand, or repetitive admin is the best first place to improve.',
    tags: ['Process audit', 'Local SEO', 'Ads'],
    href: industryHref('laundromats'),
  },
  {
    name: 'HVAC and Plumbing',
    detail:
      'Map the pressure points across urgent calls, dispatch qualification, ad spend, and follow-up workflows.',
    tags: ['Process audit', 'Voice agent', 'SEO'],
    href: industryHref('hvac-and-plumbing'),
  },
  {
    name: 'Real Estate Teams',
    detail:
      'Clarify where qualification, routing, and lead follow-up should be automated so agents stay focused on serious prospects.',
    tags: ['Process audit', 'Voice agent', 'Routing'],
    href: industryHref('real-estate-teams'),
  },
];

const faqs = [
  {
    q: 'How is this different from using ChatGPT?',
    a: 'ChatGPT is a tool. Caliperworks starts with the workflow, then identifies where voice, SEO, ads, routing, or other automation actually belongs.',
  },
  {
    q: 'Why start with a process audit?',
    a: 'Because most teams have more than one possible AI use case. The audit shows which one deserves implementation first and which ones should wait.',
  },
  {
    q: 'Will this only help businesses that need faster phone coverage?',
    a: 'No. Voice is one possible outcome. The audit can also surface search, ads, intake, follow-up, routing, or reporting improvements.',
  },
  {
    q: 'How involved is my team in the setup?',
    a: 'Very involved. We build collaboratively with your team so the system supports your actual operating model instead of forcing a new one.',
  },
  {
    q: 'What happens after the audit?',
    a: 'You get a prioritized rollout path. That might lead to voice implementation, SEO and ads work, workflow automation, or a sequence of changes over time.',
  },
];
---

<Layout
  title="Caliperworks | AI Process Audits for Service Businesses"
  description="Caliperworks helps service businesses run AI process audits to uncover where voice agents, SEO, ad automation, and workflow improvements will have the most impact."
>
  <div class="font-sans overflow-x-hidden bg-white text-xl leading-relaxed text-slate-900">
    <SiteHeader />

    <section
      data-cal-floating-threshold
      class="relative border-b-2 border-slate-100 bg-white px-6 pb-24 pt-12 md:pt-20"
    >
      <div class="mx-auto grid max-w-7xl items-center gap-14 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="relative z-10">
          <div class="mb-8 inline-flex items-center gap-3 rounded-full border border-blue-100 bg-blue-50 px-4 py-2">
            <span class="h-2 w-2 rounded-full bg-blue-600"></span>
            <span class="text-sm font-bold tracking-tight text-blue-900">{availabilityString}</span>
          </div>
          <h1 class="max-w-5xl font-serif text-6xl font-black leading-tight tracking-tight text-slate-900 md:text-8xl">
            {hero.headline}
          </h1>
          <p class="mt-8 max-w-3xl text-xl font-medium leading-relaxed text-slate-600 md:text-2xl">
            {hero.subheadline}
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <CalTriggerButton
              label={hero.cta}
              class="rounded-2xl bg-blue-800 px-10 py-5 text-xl font-black text-white shadow-xl transition-all hover:-translate-y-1 hover:bg-slate-900"
            />
            <a
              href={inquiryMailto}
              class="rounded-2xl border-2 border-slate-900 px-8 py-5 text-lg font-black text-slate-900 transition-colors hover:border-blue-800 hover:text-blue-800"
            >
              Contact Us
            </a>
          </div>
          <a
            href="/services/"
            class="mt-6 inline-flex items-center gap-3 text-lg font-black text-slate-900 transition-colors hover:text-blue-800"
          >
            Explore Services
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="relative">
          <div class="rounded-[2.75rem] border-4 border-slate-900 bg-white p-8 shadow-[20px_20px_0_0_rgba(15,23,42,1)]">
            <div class="mb-6 inline-flex rounded-full bg-slate-900 px-4 py-2 text-xs font-black uppercase tracking-[0.3em] text-blue-300">
              Audit Canvas
            </div>

            <div class="grid gap-6">
              <div class="rounded-[2rem] border-2 border-slate-200 bg-slate-50 p-6">
                <div class="text-xs font-black uppercase tracking-[0.3em] text-slate-400">What we inspect</div>
                <div class="mt-4 grid gap-4 md:grid-cols-2">
                  {auditAreas.map((area) => (
                    <div class="rounded-2xl border border-slate-200 bg-white p-4">
                      <div class="text-sm font-black uppercase tracking-[0.2em] text-blue-700">{area.title}</div>
                      <p class="mt-3 text-base leading-relaxed text-slate-600">{area.detail}</p>
                    </div>
                  ))}
                </div>
              </div>

              <div class="grid gap-6 lg:grid-cols-[0.85fr_1.15fr]">
                <div class="rounded-[2rem] border-2 border-slate-200 bg-white p-6">
                  <div class="text-xs font-black uppercase tracking-[0.3em] text-slate-400">Common findings</div>
                  <div class="mt-4 flex flex-wrap gap-2">
                    {auditFindings.map((finding) => (
                      <span class="rounded-full border border-emerald-200 bg-emerald-50 px-3 py-2 text-xs font-black uppercase tracking-[0.2em] text-emerald-800">
                        {finding}
                      </span>
                    ))}
                  </div>
                </div>

                <div class="rounded-[2rem] border-2 border-slate-200 bg-slate-900 p-6 text-white">
                  <div class="text-xs font-black uppercase tracking-[0.3em] text-blue-300">Likely rollout paths</div>
                  <div class="mt-4 grid gap-3">
                    {rolloutPaths.map((path) => (
                      <a
                        href={path.href}
                        class="rounded-2xl border border-slate-700 bg-slate-800/80 p-4 transition-colors hover:border-blue-400 hover:bg-slate-800"
                      >
                        <div class="text-lg font-black">{path.title}</div>
                        <p class="mt-2 text-sm leading-relaxed text-slate-300">{path.detail}</p>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="absolute -right-6 -top-6 -z-10 h-32 w-32 rounded-full bg-blue-100 blur-3xl"></div>
          <div class="absolute -bottom-8 -left-4 -z-10 h-28 w-28 rounded-full bg-emerald-100 blur-3xl"></div>
        </div>
      </div>
    </section>

    <section class="border-y-2 border-slate-900 bg-slate-100 px-6 py-24">
      <div class="mx-auto grid max-w-7xl gap-12 md:grid-cols-[0.85fr_1.15fr] md:items-start">
        <div>
          <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">Why this works</div>
          <h2 class="mt-6 font-serif text-5xl font-black leading-tight md:text-6xl">
            Start with the workflow, not the tool.
          </h2>
          <div class="mt-8 h-2 w-32 bg-blue-800"></div>
        </div>
        <div class="space-y-8">
          <p class="border-l-4 border-blue-800 pl-8 text-2xl font-medium italic leading-relaxed text-slate-700">
            Most businesses do not need a standalone AI product. They need clarity on where calls,
            intake, search, ad spend, and follow-up break down, then a plan for which improvement
            matters first.
          </p>
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-[1.75rem] border-2 border-slate-200 bg-white p-6">
              <div class="text-sm font-black uppercase tracking-[0.25em] text-blue-700">Audit first</div>
              <p class="mt-4 text-lg leading-relaxed text-slate-600">
                Use the audit to decide whether the next move should be voice, SEO, ads, routing,
                reporting, or a sequence across several of them.
              </p>
            </div>
            <div class="rounded-[1.75rem] border-2 border-slate-200 bg-white p-6">
              <div class="text-sm font-black uppercase tracking-[0.25em] text-blue-700">Implement second</div>
              <p class="mt-4 text-lg leading-relaxed text-slate-600">
                Once the bottleneck is clear, the service pages become implementation paths rather
                than disconnected offers.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="solutions" class="bg-white px-6 py-24">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
          <div class="max-w-3xl">
            <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">Services</div>
            <h2 class="mt-6 font-serif text-5xl font-black italic md:text-6xl">
              What the audit can lead to
            </h2>
            <p class="mt-6 text-xl leading-relaxed text-slate-600">
              The homepage should preview the service mix. The deeper details live on the service
              pages, and the audit decides which path deserves attention first.
            </p>
          </div>
          <a
            href="/services/"
            class="inline-flex items-center gap-3 text-lg font-black text-slate-900 transition-colors hover:text-blue-800"
          >
            View all services
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="mt-14 grid gap-8 lg:grid-cols-3">
          {solutions.map((solution) => (
            <article class="flex h-full flex-col rounded-[2.5rem] border-4 border-slate-900 bg-white p-10 shadow-sm transition-all hover:-translate-y-2 hover:shadow-[16px_16px_0_0_rgba(15,23,42,1)]">
              <div class="text-sm font-black uppercase tracking-[0.25em] text-blue-700">{solution.subtitle}</div>
              <h3 class="mt-4 font-serif text-4xl font-black leading-tight">{solution.title}</h3>
              <p class="mt-6 flex-grow text-xl font-medium leading-relaxed text-slate-600">{solution.description}</p>
              <a
                href={solution.href}
                class="mt-8 inline-flex items-center gap-3 text-base font-black text-slate-900 transition-colors hover:text-blue-800"
              >
                {solution.linkLabel}
                <span aria-hidden="true">→</span>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="results" class="border-y-2 border-slate-900 bg-slate-900 px-6 py-24 text-white">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
          <div class="max-w-3xl">
            <div class="text-sm font-black uppercase tracking-[0.3em] text-emerald-300">Proof</div>
            <h2 class="mt-6 font-serif text-5xl font-black italic text-white md:text-6xl">
              Selected client outcomes
            </h2>
            <p class="mt-6 text-xl leading-relaxed text-slate-300">
              Short examples from the business perspective, tied to the kinds of changes the audit
              can uncover.
            </p>
          </div>
          <a
            href="/case-studies/"
            class="inline-flex items-center gap-3 text-lg font-black text-emerald-300 transition-colors hover:text-white"
          >
            Explore case studies
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="mt-14 grid gap-8 xl:grid-cols-3">
          {testimonials.map((testimonial) => (
            <article class="rounded-[2.5rem] border-4 border-slate-800 bg-slate-800/70 p-10">
              <p class="text-2xl font-serif font-black leading-snug italic text-slate-100 md:text-[2rem]">
                "{testimonial.quote}"
              </p>
              <div class="mt-8 flex flex-wrap gap-3">
                {testimonial.metrics.map((metric) => (
                  <span class="rounded-xl border-2 border-emerald-500/40 bg-emerald-500/10 px-4 py-2 text-xs font-black uppercase tracking-[0.2em] text-emerald-300">
                    {metric}
                  </span>
                ))}
              </div>
              <div class="mt-8 border-t-2 border-slate-700 pt-6 text-lg font-bold text-slate-300">
                {testimonial.author}
                <div class="text-sm font-black uppercase tracking-[0.2em] text-slate-500">
                  {testimonial.location}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="expertise" class="bg-slate-100 px-6 py-24">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
          <div class="max-w-3xl">
            <div class="text-sm font-black uppercase tracking-[0.3em] text-blue-700">Industries</div>
            <h2 class="mt-6 font-serif text-5xl font-black italic md:text-6xl">
              Industries we already understand
            </h2>
            <p class="mt-6 text-xl leading-relaxed text-slate-600">
              These pages are still in the project. The homepage now points back to them so users
              can move from the audit story into industry-specific details.
            </p>
          </div>
          <a
            href="/industries/"
            class="inline-flex items-center gap-3 text-lg font-black text-slate-900 transition-colors hover:text-blue-800"
          >
            Explore industries
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="mt-14 grid gap-8 md:grid-cols-2 xl:grid-cols-3">
          {industries.map((industry) => (
            <a
              href={industry.href}
              class="group flex h-full flex-col rounded-[2.25rem] border-4 border-slate-200 bg-white p-8 transition-all hover:border-blue-600 hover:shadow-xl"
            >
              <h3 class="text-3xl font-black text-slate-900 transition-colors group-hover:text-blue-800">
                {industry.name}
              </h3>
              <p class="mt-5 flex-grow text-lg leading-relaxed text-slate-600">{industry.detail}</p>
              <div class="mt-8 flex flex-wrap gap-2">
                {industry.tags.map((tag) => (
                  <span class="rounded-full border border-blue-100 bg-blue-50 px-3 py-1 text-xs font-black uppercase tracking-[0.2em] text-blue-800">
                    {tag}
                  </span>
                ))}
              </div>
              <span class="mt-8 inline-flex items-center gap-3 text-base font-black text-slate-900 transition-colors group-hover:text-blue-800">
                See {industry.name} detail
                <span aria-hidden="true">→</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="faq" class="bg-white px-6 py-24">
      <div class="mx-auto max-w-4xl">
        <h2 class="text-center font-serif text-6xl font-black italic">Common Questions</h2>
        <div class="mt-16 space-y-8">
          {faqs.map((faq) => (
            <div class="overflow-hidden rounded-[2rem] border-4 border-slate-900 shadow-[12px_12px_0_0_rgba(15,23,42,1)] transition-all duration-300 hover:shadow-none">
              <div class="bg-slate-900 p-8 text-2xl font-black text-white">{faq.q}</div>
              <div class="bg-white p-10 text-xl font-medium text-slate-700">{faq.a}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section
      id="contact"
      class="relative overflow-hidden border-t-2 border-slate-900 bg-blue-800 px-6 py-32 text-center text-white"
    >
      <div class="relative z-10 mx-auto max-w-4xl">
        <h2 class="mb-12 font-serif text-6xl font-black tracking-tighter italic md:text-8xl">
          Start with the workflow.
        </h2>
        <p class="mb-16 text-3xl font-medium leading-relaxed text-blue-100">
          We can review your intake, phone coverage, follow-up, search visibility, and current
          marketing system with you, then outline the changes worth making first.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <CalTriggerButton
            label="Schedule Discovery Call"
            class="rounded-3xl bg-white px-12 py-7 text-2xl font-black text-blue-900 shadow-[0_30px_90px_rgba(0,0,0,0.3)] transition-transform hover:scale-105 hover:bg-slate-100 active:scale-95 md:px-20 md:py-10 md:text-4xl"
          />
          <a
            href={inquiryMailto}
            class="rounded-3xl border-2 border-white/70 px-12 py-7 text-2xl font-black text-white transition-colors hover:border-white hover:bg-white/10 md:px-20 md:py-10 md:text-4xl"
          >
            Contact Us
          </a>
        </div>
        <div class="mt-10 flex flex-wrap justify-center gap-4 text-sm font-black uppercase tracking-[0.2em] text-blue-100">
          <a href="/services/" class="transition-colors hover:text-white">Services</a>
          <a href="/industries/" class="transition-colors hover:text-white">Industries</a>
          <a href="/case-studies/" class="transition-colors hover:text-white">Case Studies</a>
        </div>
      </div>
      <div class="pointer-events-none absolute -bottom-10 -right-20 select-none text-[20rem] font-black italic tracking-tighter text-white/5">
        CALIPER
      </div>
    </section>

    <footer class="border-t-2 border-slate-800 bg-slate-900 px-6 py-24 text-slate-400">
      <div class="mx-auto mb-24 flex max-w-7xl flex-col items-start justify-between gap-16 md:flex-row">
        <div>
          <div class="mb-6 text-4xl font-black tracking-tighter text-white">CALIPERWORKS</div>
          <p class="max-w-md text-2xl font-medium italic leading-snug text-slate-500">
            Audit first. Then implement the voice, search, ad, and workflow changes that actually fit.
          </p>
        </div>
        <div class="flex flex-wrap gap-16 text-lg font-bold">
          <div class="space-y-4">
            <div class="mb-4 text-xs font-black uppercase tracking-[0.3em] text-blue-500">Explore</div>
            <a href="/services/" class="block transition-colors hover:text-white">Services</a>
            <a href="/case-studies/" class="block transition-colors hover:text-white">Case Studies</a>
            <a href="/industries/" class="block transition-colors hover:text-white">Industries</a>
          </div>
          <div class="space-y-4">
            <div class="mb-4 text-xs font-black uppercase tracking-[0.3em] text-blue-500">Start</div>
            <a href={serviceHref('ai-process-audits')} class="block transition-colors hover:text-white">AI Process Audits</a>
            <a href={serviceHref('voice-agents')} class="block transition-colors hover:text-white">Voice Agents</a>
            <a href={serviceHref('seo-and-ads-automation')} class="block transition-colors hover:text-white">SEO and Ads</a>
          </div>
          <div class="space-y-4">
            <div class="mb-4 text-xs font-black uppercase tracking-[0.3em] text-blue-500">Contact</div>
            <div class="flex flex-wrap gap-3">
              <CalTriggerButton
                label="Schedule Discovery Call"
                class="rounded-full bg-white px-5 py-3 text-sm font-black text-slate-900 transition-colors hover:bg-blue-100"
              />
              <a
                href={inquiryMailto}
                class="rounded-full border border-slate-600 px-5 py-3 text-sm font-black text-white transition-colors hover:border-blue-400 hover:text-blue-300"
              >
                Contact Us
              </a>
            </div>
            <a href={inquiryMailto} class="block transition-colors hover:text-white">pranit@caliperworks.com</a>
          </div>
        </div>
      </div>
      <div class="mx-auto mt-20 flex max-w-7xl flex-col items-center justify-between gap-8 border-t border-slate-800 pt-12 text-sm font-bold uppercase tracking-[0.2em] opacity-30 md:flex-row">
        <div>&copy; 2026 Caliperworks. Audit first, then implement with intent.</div>
        <div class="flex gap-4">
          <div class="h-1 w-12 bg-slate-700"></div>
          <div class="h-1 w-12 bg-slate-700"></div>
          <div class="h-1 w-12 bg-slate-700"></div>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<style>
  :global(body) {
    background-color: #ffffff;
    scroll-behavior: smooth;
  }

  .font-serif {
    font-family: 'Fraunces', serif;
  }

