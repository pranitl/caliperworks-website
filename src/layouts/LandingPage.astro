---
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import GapReviewForm from '../components/GapReviewForm.astro';
import Layout from './Layout.astro';
import { gapReviewHref } from '../data/site';
import {
  homeContactSection,
  homeFaqs,
  homeFeaturedIndustries,
  homeHero,
  homeMeta,
  homeNavItems,
  homeSectionIds,
  homeSolutions,
  homeTestimonials,
} from '../data/home';
import { organizationSchema, websiteSchema } from '../lib/seo';

const structuredData = [organizationSchema(), websiteSchema()];
---

<Layout title={homeMeta.title} description={homeMeta.description} structuredData={structuredData}>
  <SiteHeader navItems={homeNavItems} />
  <main class="overflow-hidden bg-[#fbfaf7] text-slate-950">
    <section class="border-b border-slate-200 px-6 py-20 md:py-28">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div>
          <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">{homeHero.eyebrow}</div>
          <h1 class="mt-6 max-w-4xl text-6xl font-semibold leading-[0.98] tracking-[-0.06em] md:text-8xl">{homeHero.headline}</h1>
          <p class="mt-8 max-w-2xl text-xl leading-8 text-slate-600">{homeHero.subheadline}</p>
          <div class="mt-9 flex flex-wrap items-center gap-5">
            <a href={gapReviewHref} class="rounded-lg bg-blue-700 px-6 py-4 text-sm font-bold text-white transition-colors hover:bg-slate-900">{homeHero.primaryCtaLabel}</a>
            <a href={`#${homeSectionIds.results}`} class="text-sm font-bold text-blue-800 hover:text-slate-950">{homeHero.secondaryCtaLabel} →</a>
          </div>
        </div>

        <div class="relative min-h-[360px] border-l border-slate-200 pl-8 md:min-h-[430px] md:pl-12">
          <div class="absolute inset-y-0 left-8 right-0 opacity-70" style="background-image: linear-gradient(#dbe5f2 1px, transparent 1px), linear-gradient(90deg, #dbe5f2 1px, transparent 1px); background-size: 48px 48px;"></div>
          <svg class="relative z-10 h-full min-h-[360px] w-full text-blue-700 md:min-h-[430px]" viewBox="0 0 560 430" fill="none" aria-label="Demand moves from discovery through capture and qualification to the next step">
            <path d="M40 288 C128 288 138 150 226 150 S316 268 404 268 S466 190 520 190" stroke="currentColor" stroke-width="2" />
            <circle cx="40" cy="288" r="6" fill="#fbfaf7" stroke="currentColor" stroke-width="2" />
            <circle cx="226" cy="150" r="6" fill="#fbfaf7" stroke="currentColor" stroke-width="2" />
            <circle cx="404" cy="268" r="6" fill="#fbfaf7" stroke="currentColor" stroke-width="2" />
            <circle cx="520" cy="190" r="6" fill="#fbfaf7" stroke="currentColor" stroke-width="2" />
            <text x="28" y="325" fill="#475569" font-size="14">Find</text>
            <text x="205" y="120" fill="#475569" font-size="14">Capture</text>
            <text x="380" y="305" fill="#475569" font-size="14">Qualify</text>
            <text x="492" y="160" fill="#475569" font-size="14">Route</text>
          </svg>
        </div>
      </div>
    </section>

    <section id={homeSectionIds.solutions} class="px-6 py-20 md:py-28">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-10 lg:grid-cols-[0.7fr_1.3fr]">
          <div>
            <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">One connected path</div>
            <h2 class="mt-5 max-w-lg text-4xl font-semibold leading-tight tracking-[-0.045em] md:text-6xl">Improve the constraint, not the amount of software.</h2>
          </div>
          <div class="border-t border-slate-300">
            {homeSolutions.map((solution) => (
              <a href={solution.href} class="group grid gap-5 border-b border-slate-300 py-8 sm:grid-cols-[4rem_0.7fr_1.3fr]">
                <div class="text-sm font-semibold text-blue-700">{solution.number}</div>
                <h3 class="text-2xl font-semibold tracking-[-0.025em]">{solution.title}</h3>
                <p class="leading-7 text-slate-600">{solution.description} <span class="ml-1 text-blue-700 transition-transform group-hover:translate-x-1">→</span></p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="border-y border-slate-200 bg-[#f2f6fb] px-6 py-20 md:py-24">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-12 lg:grid-cols-2">
          <div class="border-r-0 border-slate-300 lg:border-r lg:pr-12">
            <div class="text-xs font-bold uppercase tracking-[0.2em] text-blue-700">Packaged SEO execution</div>
            <h2 class="mt-5 text-4xl font-semibold tracking-[-0.04em]">A visible monthly scope.</h2>
            <p class="mt-5 max-w-xl text-lg leading-8 text-slate-600">Local visibility plans are priced by execution pace. Every plan includes the same strategy and quality standard, with different monthly output.</p>
            <div class="mt-7 text-lg font-semibold text-slate-900">From $499/month · $2,000 setup · six-month minimum</div>
            <a href="/pricing/" class="mt-7 inline-flex text-sm font-bold text-blue-800">View SEO pricing →</a>
          </div>
          <div>
            <div class="text-xs font-bold uppercase tracking-[0.2em] text-blue-700">Custom implementation</div>
            <h2 class="mt-5 text-4xl font-semibold tracking-[-0.04em]">Scoped around the workflow.</h2>
            <p class="mt-5 max-w-xl text-lg leading-8 text-slate-600">Voice agents, ads workflows, and operational automation depend on routing rules, integrations, handoffs, support, and the systems already in place.</p>
            <a href={gapReviewHref} class="mt-7 inline-flex text-sm font-bold text-blue-800">Get the gap review →</a>
          </div>
        </div>
      </div>
    </section>

    <section id={homeSectionIds.results} class="px-6 py-20 md:py-28">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-10 lg:grid-cols-[0.7fr_1.3fr]">
          <div>
            <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Selected outcomes</div>
            <h2 class="mt-5 max-w-md text-4xl font-semibold leading-tight tracking-[-0.04em] md:text-5xl">Proof stays tied to its context.</h2>
          </div>
          <div class="grid gap-px border-y border-slate-300 bg-slate-300 md:grid-cols-3">
            {homeTestimonials.map((result) => (
              <a href={result.href} class="bg-[#fbfaf7] p-7 transition-colors hover:bg-white">
                <div class="text-4xl font-semibold tracking-[-0.04em] text-slate-950">{result.metric}</div>
                <div class="mt-2 font-semibold text-slate-800">{result.label}</div>
                <div class="mt-6 text-sm leading-6 text-slate-500">{result.context}</div>
              </a>
            ))}
          </div>
        </div>
        <p class="mt-6 text-sm text-slate-500">Prior engagements. Results vary by market, competition, starting point, and implementation.</p>
      </div>
    </section>

    <section id={homeSectionIds.expertise} class="border-y border-slate-200 bg-white px-6 py-20 md:py-24">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
          <div>
            <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Industries</div>
            <h2 class="mt-5 text-4xl font-semibold tracking-[-0.04em] md:text-5xl">Broad offer. Industry-specific constraints.</h2>
          </div>
          <a href="/industries/" class="text-sm font-bold text-blue-800">View all industries →</a>
        </div>
        <div class="mt-12 border-t border-slate-300">
          {homeFeaturedIndustries.map((industry) => (
            <a href={industry.href} class="grid gap-3 border-b border-slate-300 py-6 transition-colors hover:text-blue-800 md:grid-cols-[0.7fr_1.3fr]">
              <div class="text-xl font-semibold">{industry.name}</div>
              <div class="text-base leading-7 text-slate-600">{industry.detail}</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id={homeSectionIds.faq} class="px-6 py-20 md:py-28">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.7fr_1.3fr]">
        <div>
          <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Common questions</div>
          <h2 class="mt-5 text-4xl font-semibold tracking-[-0.04em] md:text-5xl">Before the review.</h2>
        </div>
        <div class="border-t border-slate-300">
          {homeFaqs.map((faq) => (
            <details class="border-b border-slate-300 py-6">
              <summary class="cursor-pointer list-none pr-8 text-xl font-semibold tracking-[-0.02em]">{faq.question}</summary>
              <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section id="gap-review" class="border-y border-slate-200 bg-[#f2f6fb] px-6 py-20 md:py-28">
      <div class="mx-auto max-w-7xl">
        <div class="mb-12 max-w-3xl">
          <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">{homeContactSection.eyebrow}</div>
          <h2 class="mt-5 text-5xl font-semibold leading-[1.02] tracking-[-0.055em] md:text-7xl">{homeContactSection.headline}</h2>
          <p class="mt-7 text-xl leading-8 text-slate-600">{homeContactSection.body}</p>
        </div>
        <GapReviewForm deliverables={homeContactSection.deliverables} />
      </div>
    </section>
  </main>
  <SiteFooter />
</Layout>
