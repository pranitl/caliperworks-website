---
import {
  createMailto,
  gapReviewHref,
  industries,
  industryHref,
  services,
  serviceHref,
  siteConfig,
  useCases,
  useCaseHref,
} from '../data/site';

const reviewHref = gapReviewHref;
---

<footer class="border-t border-slate-200 bg-[#fbfaf7] px-6 py-16 text-slate-600">
  <div class="mx-auto grid max-w-7xl gap-12 md:grid-cols-[1.4fr_repeat(3,1fr)]">
    <div>
      <div class="text-2xl font-black tracking-[-0.045em] text-slate-950">{siteConfig.name.toUpperCase()}</div>
      <p class="mt-5 max-w-md text-base leading-7">{siteConfig.tagline}</p>
      <a href={reviewHref} class="mt-7 inline-flex rounded-lg bg-blue-700 px-5 py-3 text-sm font-bold text-white hover:bg-slate-900">
        Get the Gap Review
      </a>
    </div>
    <div>
      <div class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-blue-700">Use cases</div>
      <div class="space-y-3 text-sm font-medium">
        {useCases.map((useCase) => <a href={useCaseHref(useCase.slug)} class="block hover:text-blue-800">{useCase.shortLabel}</a>)}
      </div>
    </div>
    <div>
      <div class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-blue-700">Services</div>
      <div class="space-y-3 text-sm font-medium">
        {services.map((service) => <a href={serviceHref(service.slug)} class="block hover:text-blue-800">{service.name}</a>)}
      </div>
    </div>
    <div>
      <div class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-blue-700">Industries</div>
      <div class="space-y-3 text-sm font-medium">
        {industries.map((industry) => <a href={industryHref(industry.slug)} class="block hover:text-blue-800">{industry.name}</a>)}
        <a href={createMailto()} class="block pt-2 text-slate-950 hover:text-blue-800">{siteConfig.email}</a>
      </div>
    </div>
  </div>
  <div class="mx-auto mt-14 max-w-7xl border-t border-slate-200 pt-7 text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">
    &copy; 2026 {siteConfig.name}. Practical growth systems for service businesses.
  </div>
</footer>
