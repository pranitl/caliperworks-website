---
import CalTriggerButton from './CalTriggerButton.astro';
import { createMailto } from '../data/site';

interface Props {
  headline: string;
  body: string;
  buttonText?: string;
  subject?: string;
}

const {
  headline,
  body,
  buttonText = 'Start with a Process Audit',
  subject = 'Caliperworks Inquiry - AI Process Audit',
} = Astro.props;

const href = createMailto(subject);
---

<section class="border-t-2 border-slate-900 bg-blue-800 px-6 py-20 text-white">
  <div class="mx-auto max-w-5xl text-center">
    <h2 class="font-serif text-4xl font-black italic tracking-tight md:text-6xl">{headline}</h2>
    <p class="mx-auto mt-6 max-w-3xl text-xl leading-relaxed text-blue-100">{body}</p>
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <CalTriggerButton
        label={buttonText}
        class="rounded-3xl bg-white px-10 py-5 text-xl font-black text-blue-900 transition-transform hover:scale-105 hover:bg-slate-100"
      />
      <a
        href={href}
        class="rounded-3xl border-2 border-white/70 px-10 py-5 text-xl font-black text-white transition-colors hover:border-white hover:bg-white/10"
      >
        Contact Us
      </a>
    </div>
  </div>
</section>
