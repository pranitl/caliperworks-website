---
import { gapReviewHref } from '../data/site';

type LinkCta = { kind: 'link'; label: string; href: string };

interface Props {
  headline: string;
  body: string;
  primaryCta?: LinkCta;
  secondaryCta?: LinkCta;
}

const {
  headline,
  body,
  primaryCta = { kind: 'link', label: 'Get the Gap Review', href: gapReviewHref },
  secondaryCta = { kind: 'link', label: 'See relevant proof', href: '/case-studies/' },
} = Astro.props;

const primaryHref = primaryCta.href;
const secondaryHref = secondaryCta.href;
---

<section class="border-y border-slate-200 bg-[#f2f6fb] px-6 py-20 md:py-28">
  <div class="mx-auto grid max-w-7xl gap-10 md:grid-cols-[1.2fr_0.8fr] md:items-end">
    <div>
      <div class="text-xs font-bold uppercase tracking-[0.22em] text-blue-700">Start with the constraint</div>
      <h2 class="mt-5 max-w-3xl text-4xl font-semibold leading-[1.05] tracking-[-0.045em] text-slate-950 md:text-6xl">{headline}</h2>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">{body}</p>
    </div>
    <div class="flex flex-wrap gap-4 md:justify-end">
      <a href={primaryHref} class="rounded-lg bg-blue-700 px-6 py-4 text-sm font-bold text-white transition-colors hover:bg-slate-900">
        {primaryCta.label}
      </a>
      <a href={secondaryHref} class="rounded-lg border border-slate-300 px-6 py-4 text-sm font-bold text-slate-900 transition-colors hover:border-blue-700 hover:text-blue-800">
        {secondaryCta.label}
      </a>
    </div>
  </div>
</section>
