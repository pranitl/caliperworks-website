---
import { gapReviewHref, mainNav } from '../data/site';

interface NavItem {
  href: string;
  label: string;
}

interface Props {
  navItems?: readonly NavItem[];
}

const { navItems = mainNav } = Astro.props;
const reviewHref = gapReviewHref;
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-[#fbfaf7]/95 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-5">
    <a href="/" class="text-xl font-black tracking-[-0.045em] text-slate-950 md:text-2xl">
      CALIPERWORKS
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-7 text-sm font-semibold text-slate-600 lg:flex">
      {navItems.map((item) => (
        <a href={item.href} class="border-b border-transparent py-2 transition-colors hover:border-blue-700 hover:text-blue-800">
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href={reviewHref}
      class="hidden rounded-lg bg-blue-700 px-5 py-3 text-sm font-bold text-white transition-colors hover:bg-slate-900 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-700 lg:inline-flex"
    >
      Get the Gap Review
    </a>

    <details class="relative lg:hidden">
      <summary class="cursor-pointer list-none rounded-lg border border-slate-300 px-4 py-2 text-sm font-bold text-slate-900">
        Menu
      </summary>
      <div class="absolute right-0 top-[calc(100%+0.75rem)] z-50 w-72 rounded-xl border border-slate-200 bg-[#fbfaf7] p-4 shadow-xl shadow-slate-900/10">
        <nav aria-label="Mobile primary" class="grid gap-1 text-sm font-semibold text-slate-800">
          {navItems.map((item) => (
            <a href={item.href} class="rounded-md px-3 py-3 transition-colors hover:bg-slate-100 hover:text-blue-800">
              {item.label}
            </a>
          ))}
        </nav>
        <a href={reviewHref} class="mt-3 block rounded-lg bg-blue-700 px-4 py-3 text-center text-sm font-bold text-white">
          Get the Gap Review
        </a>
      </div>
    </details>
  </div>
</header>
