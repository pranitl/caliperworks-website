---
import CalTriggerButton from './CalTriggerButton.astro';
import { createMailto, mainNav } from '../data/site';

const contactMailto = createMailto();
---

<header class="sticky top-0 z-50 border-b-2 border-slate-900 bg-white/95 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4">
    <a href="/" class="text-2xl font-black tracking-tighter text-slate-900">
      CALIPERWORKS
    </a>
    <nav aria-label="Primary" class="hidden items-center gap-8 text-sm font-bold text-slate-700 lg:flex">
      {mainNav.map((item) => (
        <a href={item.href} class="transition-colors hover:text-blue-800">
          {item.label}
        </a>
      ))}
    </nav>
    <div class="hidden items-center gap-2 sm:gap-3 lg:flex">
      <CalTriggerButton
        label="Schedule Discovery Call"
        mobileLabel="Schedule"
        class="rounded-full bg-slate-900 px-3 py-2 text-xs font-black whitespace-nowrap text-white transition-all hover:bg-blue-800 sm:px-5 sm:py-3 sm:text-sm"
      />
      <a
        href={contactMailto}
        class="rounded-full border-2 border-slate-900 px-3 py-2 text-xs font-black whitespace-nowrap text-slate-900 transition-colors hover:border-blue-800 hover:text-blue-800 sm:px-5 sm:py-3 sm:text-sm"
      >
        Contact Us
      </a>
    </div>
    <div class="flex items-center gap-2 lg:hidden">
      <a
        href="/pricing/"
        class="rounded-full bg-slate-900 px-3 py-2 text-xs font-black whitespace-nowrap text-white transition-colors hover:bg-blue-800 sm:px-4 sm:py-3 sm:text-sm"
      >
        Pricing
      </a>
      <details class="relative">
        <summary class="list-none cursor-pointer rounded-full border-2 border-slate-900 px-3 py-2 text-xs font-black whitespace-nowrap text-slate-900 transition-colors hover:border-blue-800 hover:text-blue-800 sm:px-4 sm:py-3 sm:text-sm">
          Menu
        </summary>
        <div class="absolute right-0 top-[calc(100%+0.75rem)] z-50 w-64 rounded-[1.5rem] border-2 border-slate-900 bg-white p-4 shadow-[10px_10px_0_0_rgba(15,23,42,1)]">
          <nav aria-label="Mobile primary" class="space-y-2 text-sm font-bold text-slate-900">
            {mainNav.map((item) => (
              <a href={item.href} class="block rounded-xl px-3 py-3 transition-colors hover:bg-slate-50 hover:text-blue-800">
                {item.label}
              </a>
            ))}
          </nav>
          <div class="mt-4 grid gap-2">
            <CalTriggerButton
              label="Schedule Discovery Call"
              mobileLabel="Schedule"
              class="rounded-xl bg-slate-900 px-4 py-3 text-sm font-black text-white transition-colors hover:bg-blue-800"
            />
            <a
              href={contactMailto}
              class="rounded-xl border-2 border-slate-900 px-4 py-3 text-center text-sm font-black text-slate-900 transition-colors hover:border-blue-800 hover:text-blue-800"
            >
              Contact Us
            </a>
          </div>
        </div>
      </details>
    </div>
  </div>
</header>
